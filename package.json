{
  "name": "winpar-golf-scorecard",
  "version": "1.0.0",
  "description": "WinPAR 高尔夫记分卡微信小程序",
  "main": "app.js",
  "scripts": {
    "deploy": "node auto-deploy.js",
    "deploy:watch": "node auto-deploy.js --watch",
    "deploy:all": "node auto-deploy.js --all",
    "test": "node scripts/test-agent.js",
    "test:unit": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "test:update-snapshots": "node scripts/test-agent.js --update-snapshots",
    "test:watch": "jest --watch",
    "test:e2e:devtools": "node scripts/devtools-smoke.js",
    "test:full": "npm run test:coverage && npm run test:e2e:devtools",
    "test:closed-loop": "node scripts/closed-loop-agent.js",
    "test:closed-loop:ff": "node scripts/closed-loop-agent.js --fail-fast",
    "defects:report": "node scripts/defect-report.js",
    "check:upload": "node scripts/check-upload-ready.js"
  },
  "keywords": [
    "golf",
    "miniprogram",
    "scorecard"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@vant/weapp": "^1.11.7"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "miniprogram-automator": "^0.12.1"
  }
}
