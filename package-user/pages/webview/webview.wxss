.page-container {
  height: 100vh;
  width: 100%;
}

.local-content {
  height: 100vh;
  background: #f5f5f5;
}

.content-box {
  padding: 32rpx;
  background: #fff;
  margin: 24rpx;
  border-radius: 16rpx;
  min-height: calc(100vh - 48rpx);
}

.content-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
  white-space: pre-wrap;
}
