<view class="container">
  <view class="card">
    <view class="section-title">意见反馈</view>
    <view class="feedback-desc">
      <text class="desc-text">您的建议是我们进步的动力！无论是功能建议、使用问题还是想说的话，都欢迎告诉我们。</text>
    </view>

    <view class="form-group">
      <text class="form-label">反馈内容</text>
      <textarea class="feedback-textarea" placeholder="说说你的想法..." maxlength="500" bindinput="onContentInput" value="{{content}}"></textarea>
      <view class="input-footer">
        <text class="char-count">{{content.length}}/500</text>
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">联系方式（选填）</text>
      <input class="form-input" placeholder="手机号 / 微信 / 邮箱，方便我们联系你" bindinput="onContactInput" value="{{contact}}" />
      <text class="contact-hint">{{contactSource || '如账号里已有手机号会自动带入，也可以手动修改'}}</text>
    </view>

    <button class="btn btn-primary submit-btn" bindtap="submitFeedback" disabled="{{!content}}">提交反馈</button>
  </view>

  <!-- 感谢提示 -->
  <view class="thank-you" wx:if="{{showThanks}}">
    <text class="thanks-icon">🙏</text>
    <text class="thanks-text">感谢您的反馈！</text>
    <text class="thanks-subtext">我们会认真阅读每一条建议</text>
  </view>
</view>
