.feedback-page {
  min-height: 100vh;
  padding: 28rpx 24rpx calc(160rpx + env(safe-area-inset-bottom));
  background: #f3f5f1;
  box-sizing: border-box;
}

.feedback-header {
  padding: 18rpx 4rpx 28rpx;
  display: flex;
  flex-direction: column;
}

.header-kicker {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.header-title {
  color: #18251b;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.25;
}

.header-subtitle {
  color: #68736a;
  font-size: 26rpx;
  line-height: 1.5;
  margin-top: 14rpx;
}

.contact-panel,
.content-panel {
  background: #ffffff;
  border: 1rpx solid rgba(27, 94, 32, 0.1);
  border-radius: 8rpx;
  padding: 28rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 45, 33, 0.06);
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.panel-title {
  color: #1e2b22;
  font-size: 30rpx;
  font-weight: 650;
}

.required-tag {
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 14rpx;
  background: rgba(255, 152, 0, 0.12);
  border-radius: 4rpx;
  color: #b45e00;
  font-size: 22rpx;
  font-weight: 600;
}

.contact-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.contact-tab {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f6f7f4;
  border: 1rpx solid #e3e8df;
  border-radius: 6rpx;
  color: #566159;
  font-size: 26rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.contact-tab.active {
  background: #e9f4ec;
  border-color: rgba(44, 143, 78, 0.45);
  color: var(--primary);
}

.phone-auth-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.phone-auth-btn {
  height: 72rpx;
  line-height: 72rpx;
  margin: 0;
  padding: 0 28rpx;
  background: var(--primary);
  border-radius: 6rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 650;
}

.phone-auth-btn::after {
  border: 0;
}

.phone-auth-note {
  flex: 1;
  color: #7a847b;
  font-size: 23rpx;
  line-height: 1.35;
}

.contact-input {
  width: 100%;
  height: 92rpx;
  padding: 0 24rpx;
  background: #f7f8f5;
  border: 1rpx solid #e1e7dc;
  border-radius: 6rpx;
  color: #202a22;
  font-size: 28rpx;
  box-sizing: border-box;
}

.contact-hint {
  display: block;
  margin-top: 12rpx;
  color: #7a847b;
  font-size: 24rpx;
  line-height: 1.4;
}

.context-strip {
  margin-bottom: 18rpx;
  padding: 16rpx 18rpx;
  background: #edf5ef;
  border-left: 6rpx solid var(--primary);
  border-radius: 6rpx;
  color: #315542;
  font-size: 24rpx;
  line-height: 1.4;
}

.feedback-textarea {
  width: 100%;
  height: 300rpx;
  padding: 24rpx;
  background: #f7f8f5;
  border: 1rpx solid #e1e7dc;
  border-radius: 6rpx;
  color: #202a22;
  font-size: 28rpx;
  line-height: 1.55;
  box-sizing: border-box;
}

.input-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.char-count {
  color: #8c958e;
  font-size: 24rpx;
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  margin: 4rpx 0 0;
  background: #1f7a43;
  border-radius: 8rpx;
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 700;
}

.submit-btn::after {
  border: 0;
}

.submit-btn[disabled] {
  background: #c7d0c7;
  color: rgba(255, 255, 255, 0.86);
}

.thank-you {
  margin-top: 22rpx;
  padding: 26rpx;
  background: #e9f4ec;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
}

.thanks-text {
  color: var(--primary);
  font-size: 30rpx;
  font-weight: 700;
}

.thanks-subtext {
  color: #5d6b61;
  font-size: 25rpx;
  line-height: 1.45;
  margin-top: 8rpx;
}
