.feedback-desc {
  padding: 20rpx 0;
  margin-bottom: 30rpx;
}

.desc-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 16rpx;
}

.textarea-wrapper {
  position: relative;
}

.feedback-textarea {
  width: 100%;
  height: 240rpx;
  padding: 24rpx;
  padding-right: 80rpx;
  background: var(--bg-gray);
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.voice-icon-btn {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(44, 143, 78, 0.1);
  border-radius: 50%;
}

.voice-icon-btn.recording {
  background: rgba(244, 67, 54, 0.1);
}

.voice-icon-btn text {
  font-size: 28rpx;
}

.input-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.char-count {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 录音弹窗 */
.recording-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.recording-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
  padding: 60rpx 80rpx;
  background: white;
  border-radius: 20rpx;
}

.recording-wave {
  display: flex;
  align-items: end;
  gap: 8rpx;
  height: 60rpx;
}

.wave-item {
  width: 8rpx;
  background: var(--primary);
  border-radius: 4rpx;
  animation: wave 0.8s infinite ease-in-out;
}

.wave-item:nth-child(1) {
  height: 20rpx;
  animation-delay: 0s;
}

.wave-item:nth-child(2) {
  height: 30rpx;
  animation-delay: 0.1s;
}

.wave-item:nth-child(3) {
  height: 45rpx;
  animation-delay: 0.2s;
}

.wave-item:nth-child(4) {
  height: 35rpx;
  animation-delay: 0.3s;
}

.wave-item:nth-child(5) {
  height: 25rpx;
  animation-delay: 0.4s;
}

@keyframes wave {
  0%, 100% {
    transform: scaleY(0.8);
  }
  50% {
    transform: scaleY(1.5);
  }
}

.recording-text {
  font-size: 28rpx;
  color: var(--text-primary);
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: var(--bg-gray);
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.contact-wrapper {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.contact-wrapper .form-input {
  flex: 1;
}

.get-contact-btn {
  background: #2c8f4e;
  color: #fff;
  font-size: 26rpx;
  padding: 0 24rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  border: none;
  flex-shrink: 0;
  margin: 0;
}

.contact-hint {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

.submit-btn {
  width: 100%;
  margin-top: 20rpx;
}

.submit-btn[disabled] {
  opacity: 0.5;
}

.thank-you {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.thanks-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.thanks-text {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 12rpx;
}

.thanks-subtext {
  font-size: 26rpx;
  color: var(--text-secondary);
}
