<view class="container">
  <!-- 骨架屏 - 首屏加载时显示 -->
  <view class="skeleton-wrapper" wx:if="{{pageLoading}}">
    <view class="skeleton-card">
      <view class="skeleton-title"></view>
      <view class="skeleton-row">
        <view class="skeleton-text skeleton-text-lg"></view>
        <view class="skeleton-text skeleton-text-sm"></view>
      </view>
    </view>
    <view class="skeleton-card">
      <view class="skeleton-title"></view>
      <view class="skeleton-grid">
        <view class="skeleton-box"></view>
        <view class="skeleton-box"></view>
      </view>
    </view>
    <view class="skeleton-card">
      <view class="skeleton-title"></view>
      <view class="skeleton-list">
        <view class="skeleton-item"></view>
        <view class="skeleton-item"></view>
      </view>
    </view>
  </view>

  <!-- 实际内容 - 加载完成后显示 -->
  <block wx:if="{{!pageLoading}}">
  <view class="home-tool-shell">
    <!-- 主状态卡：继续比赛或新建比赛 -->
    <view class="card home-status-card home-status-active" wx:if="{{hasOngoingGame && ongoingGame}}">
      <view class="home-status-top">
        <view class="home-status-badge">
          <text class="home-status-dot"></text>
          <text>进行中</text>
        </view>
        <text class="home-status-hole">第 {{ongoingGame.currentHole}}/{{ongoingGame.totalHoles}} 洞</text>
      </view>
      <text class="home-status-title">{{ongoingGame.courseName}}</text>
      <view class="home-status-metrics">
        <view class="home-status-metric">
          <text class="home-metric-label">已打杆数</text>
          <text class="home-metric-value">{{ongoingGame.myScore.totalScore}}杆</text>
        </view>
        <view class="home-status-metric">
          <text class="home-metric-label">当前差点</text>
          <text class="home-metric-value {{ongoingGame.myScore.toParClass}}">{{ongoingGame.myScore.toParText}}</text>
        </view>
        <view class="home-status-metric">
          <text class="home-metric-label">进度</text>
          <text class="home-metric-value">{{ongoingGame.myScore.holesPlayed}}/{{ongoingGame.totalHoles}}</text>
        </view>
      </view>
      <button class="btn btn-primary home-primary-btn" bindtap="goToScorecard">继续记分</button>
    </view>

    <view class="card home-status-card home-status-ready" wx:if="{{!hasOngoingGame}}">
      <view class="home-status-top">
        <view class="home-status-badge ready">
          <text>新比赛</text>
        </view>
        <text class="home-status-hole" wx:if="{{courseCount > 0}}">{{courseCount}} 个球场</text>
      </view>
      <text class="home-status-title">{{homeReadyTitle}}</text>
      <text class="home-status-subtitle">{{homeReadySubtitle}}</text>
      <button class="btn btn-primary home-primary-btn" bindtap="startNewGame">选择球场开局</button>
      <view class="home-new-user-tip" wx:if="{{homeShowNewUserTip}}">
        <text>选球场</text>
        <text class="home-tip-separator">-</text>
        <text>加球友</text>
        <text class="home-tip-separator">-</text>
        <text>开始记分</text>
      </view>
    </view>

    <view class="card home-last-setup-card" wx:if="{{!hasOngoingGame && quickStartSetup}}" bindtap="quickReuseLastSetup">
      <view class="home-last-setup-main">
        <text class="home-last-setup-kicker">上次配置</text>
        <text class="home-last-setup-title">{{quickStartSetup.courseName}}</text>
        <text class="home-last-setup-meta">{{quickStartSetup.playerText}}</text>
      </view>
      <text class="home-last-setup-action">沿用开局 ›</text>
    </view>

    <!-- 小指标行 -->
    <view class="card home-summary-card" wx:if="{{userStats.totalGames > 0}}" bindtap="goToStatsAnalysis">
      <view class="home-summary-main">
        <view class="home-summary-item">
          <text class="home-summary-value">{{userStats.totalGames}}</text>
          <text class="home-summary-label">总场次</text>
        </view>
        <view class="home-summary-item">
          <text class="home-summary-value">{{userStats.bestScore}}</text>
          <text class="home-summary-label">最佳成绩</text>
        </view>
      </view>
      <text class="home-summary-link">数据分析 ›</text>
    </view>

    <!-- 最近比赛 -->
    <view class="card home-recent-card">
      <view class="home-section-header">
        <text class="home-section-title">最近比赛</text>
        <text class="home-section-link" wx:if="{{homeHasRecentGames}}" bindtap="goToHistory">全部</text>
      </view>
      <view class="home-recent-list" wx:if="{{homeHasRecentGames}}">
        <view class="home-recent-item" wx:for="{{recentGames}}" wx:key="id" bindtap="viewGame" data-gameid="{{item.id}}">
          <view class="home-recent-main">
            <text class="home-recent-name">{{item.courseName || '未知球场'}}</text>
            <text class="home-recent-meta">{{item.date || ''}} · {{item.holesPlayed || 0}}/{{item.holesTotal || 18}}洞</text>
          </view>
          <view class="home-recent-score">
            <text class="home-recent-score-num">{{item.myScore || '-'}}</text>
            <text class="home-recent-to-par {{item.toParClassName}}">{{item.toParText || '-'}}</text>
          </view>
        </view>
      </view>
      <view class="home-empty-state" wx:else>
        <text class="home-empty-title">还没有比赛记录</text>
        <text class="home-empty-text">完成第一场后，这里会显示最近成绩</text>
      </view>
    </view>
  </view>

  <!-- 进行中的比赛详情弹窗 -->
  <view class="modal {{showOngoingDetail && ongoingDetail ? 'show' : ''}}" wx:if="{{showOngoingDetail && ongoingDetail}}" bindtap="hideOngoingDetail">
    <view class="modal-content" catchtap="preventHide">
      <view class="modal-header">
        <text class="modal-title">{{ongoingDetail.courseName}}</text>
        <text class="modal-close" bindtap="hideOngoingDetail">×</text>
      </view>
      <view class="modal-body">
        <view class="detail-progress">
          <text class="detail-label">比赛进度</text>
          <text class="detail-value">第 {{ongoingDetail.currentHole}}/{{ongoingDetail.totalHoles}} 洞</text>
        </view>
        <view class="detail-section">
          <text class="detail-label">当前成绩</text>
          <view class="detail-scores">
            <view class="detail-score-row" wx:for="{{ongoingDetail.playerScores}}" wx:key="name">
              <view class="player-info-row">
                <text class="player-name">{{item.name}}</text>
                <text class="player-status {{item.toPar < 0 ? 'under' : item.toPar > 0 ? 'over' : ''}}">{{item.toPar > 0 ? '+' : ''}}{{item.toPar}}</text>
              </view>
              <text class="player-total">{{item.totalScore}}杆</text>
            </view>
          </view>
        </view>
        <button class="btn btn-primary continue-btn" bindtap="continueGameFromModal">继续比赛</button>
      </view>
    </view>
  </view>

  <!-- 我的数据详情弹窗 -->
  <view class="modal {{showStatsDetail ? 'show' : ''}}" wx:if="{{showStatsDetail}}" bindtap="hideStatsDetail">
    <view class="modal-content" catchtap="preventHide">
      <view class="modal-header">
        <text class="modal-title">数据统计</text>
        <text class="modal-close" bindtap="hideStatsDetail">×</text>
      </view>
      <view class="modal-body">
        <view class="stats-detail-grid">
          <view class="stats-detail-item">
            <text class="stats-detail-num">{{userStats.totalGames}}</text>
            <text class="stats-detail-label">总场次</text>
          </view>
          <view class="stats-detail-item">
            <text class="stats-detail-num">{{userStats.bestScore}}</text>
            <text class="stats-detail-label">最佳成绩</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</block>
</view>
