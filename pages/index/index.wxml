<view class="container">
  <!-- 骨架屏 - 首屏加载时显示 -->
  <view class="skeleton-wrapper" wx:if="{{pageLoading}}">
    <view class="skeleton-card">
      <view class="skeleton-title"></view>
      <view class="skeleton-row">
        <view class="skeleton-text skeleton-text-lg"></view>
        <view class="skeleton-text skeleton-text-sm"></view>
      </view>
    </view>
    <view class="skeleton-card">
      <view class="skeleton-title"></view>
      <view class="skeleton-grid">
        <view class="skeleton-box"></view>
        <view class="skeleton-box"></view>
      </view>
    </view>
    <view class="skeleton-card">
      <view class="skeleton-title"></view>
      <view class="skeleton-list">
        <view class="skeleton-item"></view>
        <view class="skeleton-item"></view>
      </view>
    </view>
  </view>

  <!-- 实际内容 - 加载完成后显示 -->
  <block wx:if="{{!pageLoading}}">
  <!-- 首屏价值主张 -->
  <view class="card home-hero-card" wx:if="{{!hasOngoingGame && isFirstVisit}}">
    <view class="hero-badge">WINPAR</view>
    <text class="hero-title">一场球，从记分到复盘，一次搞定</text>
    <text class="hero-subtitle">多人同步记分、拍照校准标准杆、赛后自动生成分析与海报</text>
    <view class="hero-actions">
      <button class="btn btn-primary hero-primary-btn" bindtap="startNewGame">10秒开始新比赛</button>
    </view>
  </view>

  <!-- 新手三步 -->
  <view class="card onboarding-card" wx:if="{{!hasOngoingGame && isFirstVisit}}">
    <view class="section-title">第一次用？按这3步就行</view>
    <view class="onboarding-steps">
      <view class="home-step-item">
        <text class="home-step-number">1</text>
        <view class="home-step-main">
          <text class="home-step-name">选球场</text>
          <text class="home-step-desc">支持全国球场，拍卡可校准标准杆</text>
        </view>
      </view>
      <view class="home-step-item">
        <text class="home-step-number">2</text>
        <view class="home-step-main">
          <text class="home-step-name">加球友</text>
          <text class="home-step-desc">分享加入房间，记分协作更轻松</text>
        </view>
      </view>
      <view class="home-step-item">
        <text class="home-step-number">3</text>
        <view class="home-step-main">
          <text class="home-step-name">开始记分</text>
          <text class="home-step-desc">弱网可用，赛后自动生成复盘</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 核心收益 -->
  <view class="card benefit-card" wx:if="{{!hasOngoingGame && isFirstVisit}}">
    <view class="section-title">用 WinPAR 记分的好处</view>
    <view class="benefit-grid">
      <view class="benefit-item">
        <text class="benefit-tag">省时间</text>
        <text class="benefit-text">多人同步录入，平均每场少沟通 {{welcomeStats.avgTimeSaved}} 分钟</text>
      </view>
      <view class="benefit-item">
        <text class="benefit-tag">更准确</text>
        <text class="benefit-text">拍照识别 + 重点洞位复核，减少人工抄错</text>
      </view>
      <view class="benefit-item">
        <text class="benefit-tag">有复盘</text>
        <text class="benefit-text">总杆差、推杆、趋势一页看懂，打完就能复盘</text>
      </view>
    </view>
  </view>

  <!-- 最近比赛继续入口 -->
  <view class="card quick-return-card" wx:if="{{!hasOngoingGame && latestFinishedGame}}">
    <view class="quick-return-left">
      <text class="quick-return-title">继续你的高尔夫成长</text>
      <text class="quick-return-subtitle">最近比赛：{{latestFinishedGame.courseName}} · {{latestFinishedGame.date}}</text>
    </view>
    <button class="quick-return-btn" bindtap="quickContinueLatest">查看复盘</button>
  </view>

  <!-- 进行中的比赛 -->
  <view class="card ongoing-game-card" wx:if="{{ongoingGame}}" bindtap="goToScorecard">
    <view class="ongoing-header">
      <view class="ongoing-badge">
        <text class="ongoing-dot"></text>
        <text class="ongoing-text">进行中</text>
      </view>
      <text class="ongoing-hole">第 {{ongoingGame.currentHole}}/{{ongoingGame.totalHoles}} 洞</text>
    </view>
    <text class="ongoing-course">{{ongoingGame.courseName}}</text>
    <view class="ongoing-meta">
      <text class="ongoing-meta-item">已打 {{ongoingGame.myScore.holesPlayed}}/{{ongoingGame.totalHoles}} 洞</text>
      <text class="ongoing-meta-item">我的差点 {{ongoingGame.myScore.toPar === 0 ? 'E' : (ongoingGame.myScore.toPar > 0 ? '+' : '') + ongoingGame.myScore.toPar}}</text>
    </view>
    <view class="ongoing-my-score">
      <view class="score-row">
        <view class="score-item">
          <text class="my-score-label">已打杆数</text>
          <view class="my-score-content">
            <text class="my-to-par {{ongoingGame.myScore.toPar < 0 ? 'under' : ongoingGame.myScore.toPar > 0 ? 'over' : ''}}">{{ongoingGame.myScore.toPar > 0 ? '+' : ''}}{{ongoingGame.myScore.toPar}}</text>
            <text class="my-total">{{ongoingGame.myScore.totalScore}}杆</text>
          </view>
        </view>
        <view class="score-divider"></view>
        <view class="score-item">
          <text class="my-score-label">预估成绩</text>
          <view class="my-score-content">
            <text class="my-estimated">{{ongoingGame.myScore.estimatedScore}}<text class="estimated-unit">杆</text></text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 极速开局 -->
  <view class="card quick-start-card" wx:if="{{!hasOngoingGame}}">
    <view class="quick-start-header">
      <view>
        <text class="section-title quick-start-title">极速开局</text>
        <text class="quick-start-subtitle">到球场先开局，细节可以之后补</text>
      </view>
    </view>
    <view class="quick-start-grid">
      <view class="quick-start-option primary" wx:if="{{quickStartSetup}}" bindtap="quickReuseLastSetup">
        <text class="quick-start-kicker">{{quickStartSetup.source}}</text>
        <text class="quick-start-name">{{quickStartSetup.courseName}}</text>
        <text class="quick-start-meta">{{quickStartSetup.playerText}}</text>
      </view>
      <view class="quick-start-option" bindtap="startTempGame">
        <text class="quick-start-kicker">找不到球场时</text>
        <text class="quick-start-name">临时 Par72 开局</text>
        <text class="quick-start-meta">18洞标准模板，打完再补球场</text>
      </view>
    </view>
  </view>

  <!-- 快速开始卡片 - 当没有进行中比赛时显示（上移） -->
  <view class="card start-card" wx:if="{{!hasOngoingGame}}">
    <view class="start-content">
      <view class="start-info">
        <text class="start-title">准备就绪</text>
        <text class="start-subtitle" wx:if="{{courseCount === 0}}">正在加载球场数据...完成即可开始</text>
        <text class="start-subtitle" wx:if="{{courseCount > 0}}">已有 {{courseCount}} 个全国球场，选择球场添加球员即可开始记分</text>
      </view>
      <button class="btn btn-primary start-btn" bindtap="startNewGame">开始新比赛</button>
    </view>
  </view>

  <!-- 个人数据概览 -->
  <view class="card stats-overview-card" wx:if="{{userStats.totalGames > 0}}" bindtap="goToStatsAnalysis">
    <view class="stats-header">
      <text class="section-title">我的数据</text>
      <text class="stats-arrow">›</text>
    </view>
    <view class="stats-grid">
      <view class="stat-box">
        <text class="stat-num">{{userStats.totalGames}}</text>
        <text class="stat-label">总场次</text>
      </view>
      <view class="stat-box highlight">
        <text class="stat-num">{{userStats.bestScore}}</text>
        <text class="stat-label">个人最佳</text>
      </view>
    </view>
  </view>

  <!-- 最近比赛 -->
  <view class="card recent-games-card" wx:if="{{recentGames.length > 0}}">
    <view class="recent-section-header">
      <view class="recent-title-block">
        <text class="section-title recent-section-title">最近比赛</text>
        <text class="recent-section-subtitle">最近 3 场记录</text>
      </view>
      <text class="recent-view-all" bindtap="goToHistory">查看全部</text>
    </view>
    <view class="recent-game-list">
      <view class="recent-game-item" wx:for="{{recentGames}}" wx:key="id" bindtap="viewGame" data-gameid="{{item.id}}">
        <view class="recent-game-main">
          <view class="recent-game-info">
            <text class="recent-game-name">{{item.courseName || '未知球场'}}</text>
            <text class="recent-game-date">{{item.date || ''}}</text>
          </view>
          <view class="recent-game-meta-row">
            <text class="recent-game-meta">已打 {{item.holesPlayed || 0}}/{{item.holesTotal || 18}} 洞</text>
            <text class="recent-game-meta recent-game-to-par {{'to-par-' + (item.toParClass || 'empty')}}">{{item.toParText || '-'}}</text>
          </view>
        </view>
        <view class="recent-game-scorebox">
          <text class="recent-game-score">{{item.myScore || '-'}}</text>
          <text class="recent-game-score-label">杆</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部功能区 -->
  <view class="footer-actions">
    <view class="footer-btn" catchtap="goToFeedback">
      <text class="footer-icon">💬</text>
      <text class="footer-text">意见反馈</text>
    </view>
  </view>

  <!-- 进行中的比赛详情弹窗 -->
  <view class="modal {{showOngoingDetail && ongoingDetail ? 'show' : ''}}" wx:if="{{showOngoingDetail && ongoingDetail}}" bindtap="hideOngoingDetail">
    <view class="modal-content" catchtap="preventHide">
      <view class="modal-header">
        <text class="modal-title">{{ongoingDetail.courseName}}</text>
        <text class="modal-close" bindtap="hideOngoingDetail">×</text>
      </view>
      <view class="modal-body">
        <view class="detail-progress">
          <text class="detail-label">比赛进度</text>
          <text class="detail-value">第 {{ongoingDetail.currentHole}}/{{ongoingDetail.totalHoles}} 洞</text>
        </view>
        <view class="detail-section">
          <text class="detail-label">当前成绩</text>
          <view class="detail-scores">
            <view class="detail-score-row" wx:for="{{ongoingDetail.playerScores}}" wx:key="name">
              <view class="player-info-row">
                <text class="player-name">{{item.name}}</text>
                <text class="player-status {{item.toPar < 0 ? 'under' : item.toPar > 0 ? 'over' : ''}}">{{item.toPar > 0 ? '+' : ''}}{{item.toPar}}</text>
              </view>
              <text class="player-total">{{item.totalScore}}杆</text>
            </view>
          </view>
        </view>
        <button class="btn btn-primary continue-btn" bindtap="continueGameFromModal">继续比赛</button>
      </view>
    </view>
  </view>

  <!-- 我的数据详情弹窗 -->
  <view class="modal {{showStatsDetail ? 'show' : ''}}" wx:if="{{showStatsDetail}}" bindtap="hideStatsDetail">
    <view class="modal-content" catchtap="preventHide">
      <view class="modal-header">
        <text class="modal-title">数据统计</text>
        <text class="modal-close" bindtap="hideStatsDetail">×</text>
      </view>
      <view class="modal-body">
        <view class="stats-detail-grid">
          <view class="stats-detail-item">
            <text class="stats-detail-num">{{userStats.totalGames}}</text>
            <text class="stats-detail-label">总场次</text>
          </view>
          <view class="stats-detail-item">
            <text class="stats-detail-num">{{userStats.bestScore}}</text>
            <text class="stats-detail-label">最佳成绩</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</block>
</view>
