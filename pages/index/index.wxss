}

.benefit-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #2c8f4e;
  background: #e6f5ec;
  border-radius: 999rpx;
  padding: 4rpx 14rpx;
  margin-bottom: 8rpx;
}

.benefit-text {
  display: block;
  font-size: 27rpx;
  line-height: 1.6;
