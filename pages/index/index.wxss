  flex-direction: column;
  min-width: 0;
}

.quick-return-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f3a2a;
}

.quick-return-subtitle {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #6e7f74;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.quick-return-btn {
  flex-shrink: 0;
