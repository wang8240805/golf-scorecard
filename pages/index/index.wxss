.course-card {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: white;
}

.course-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.course-name {
  font-size: 40rpx;
  font-weight: 600;
}

.course-stats {
  display: flex;
  gap: 60rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}

/* 特色球场卡片 */
.featured-course-card {
  padding: 0;
  overflow: hidden;
  margin-bottom: 30rpx;
}

.featured-image {
  position: relative;
  height: 320rpx;
  overflow: hidden;
}

.featured-bg {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1b5e20 0%, #2e7d32 50%, #4caf50 100%);
}

/* Province-specific backgrounds */
.featured-bg.beijing {
  background: linear-gradient(135deg, #8B4513 0%, #D2691E 50%, #F4A460 100%);
}

.featured-bg.shanghai {
  background: linear-gradient(135deg, #1a237e 0%, #3949ab 50%, #5c6bc0 100%);
}

.featured-bg.guangdong {
  background: linear-gradient(135deg, #00695c 0%, #00897b 50%, #26a69a 100%);
}

.featured-bg.hainan {
  background: linear-gradient(135deg, #0277bd 0%, #29b6f6 50%, #4fc3f7 100%);
}

.featured-bg.yunnan {
  background: linear-gradient(135deg, #2e7d32 0%, #43a047 50%, #66bb6a 100%);
}

.featured-bg.sichuan {
  background: linear-gradient(135deg, #5d4037 0%, #795548 50%, #8d6e63 100%);
}

.featured-bg.zhejiang {
  background: linear-gradient(135deg, #1565c0 0%, #1976d2 50%, #1e88e5 100%);
}

.featured-bg.jiangsu {
  background: linear-gradient(135deg, #c62828 0%, #d32f2f 50%, #e57373 100%);
}

.featured-icon {
  font-size: 120rpx;
  opacity: 0.3;
}

.featured-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.featured-distance {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}

.featured-info {
  padding: 30rpx;
}

.featured-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.featured-location {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
}

.featured-stats {
  display: flex;
  justify-content: space-around;
  padding: 24rpx;
  background: var(--bg-gray);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.featured-stat {
  text-align: center;
}

.featured-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.featured-label {
  font-size: 22rpx;
  color: var(--text-light);
}

.featured-btn {
  width: 100%;
}

.btn-icon {
  margin-right: 12rpx;
  font-size: 40rpx;
  font-weight: 300;
}

.player-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.player-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: var(--bg-gray);
  border-radius: 40rpx;
}

.player-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 24rpx;
  font-weight: 600;
}

.player-name {
  font-size: 28rpx;
  color: var(--text-primary);
}

.player-handicap {
  font-size: 22rpx;
  color: var(--text-light);
  background: white;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.color-picker {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.color-option {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.color-option.selected {
  border-color: var(--text-primary);
  transform: scale(1.1);
}

.btn-group {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btn-group .btn {
  flex: 1;
}

.course-section {
  margin-bottom: 30rpx;
}

.course-section:last-child {
  margin-bottom: 0;
}

.section-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  margin-left: 8rpx;
}

/* 搜索框 */
.search-box {
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  height: 72rpx;
  padding: 0 24rpx;
  background: var(--bg-gray);
  border-radius: 36rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 省份筛选 */
.province-list {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.province-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  background: var(--bg-gray);
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.province-item.active {
  background: var(--primary);
  color: white;
}

/* 定位按钮 */
.location-btn {
  padding: 8rpx 20rpx;
  background: var(--bg-gray);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: var(--primary);
}

/* 附近球场标签 */
.course-location {
  font-size: 22rpx;
  color: var(--primary);
  background: rgba(44, 143, 78, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.course-option-header text.course-location {
  color: var(--primary);
  font-weight: 600;
}

.course-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.course-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: var(--bg-gray);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.course-option.active {
  border-color: var(--primary);
  background: rgba(44, 143, 78, 0.05);
}

.course-option-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.course-option-name {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.course-location {
  font-size: 22rpx;
  color: var(--text-light);
  background: rgba(44, 143, 78, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.course-option-detail {
  font-size: 24rpx;
  color: var(--text-light);
  display: block;
}

.check-icon {
  color: var(--primary);
  font-size: 32rpx;
  font-weight: 600;
}

.game-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.game-item {
  padding: 24rpx;
  background: var(--bg-gray);
  border-radius: 12rpx;
}

.game-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.game-course {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.game-date {
  font-size: 24rpx;
  color: var(--text-light);
}

.game-meta-row {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
}

.game-meta {
  font-size: 22rpx;
  color: var(--text-secondary);
  background: #f2f5f8;
  border-radius: 16rpx;
  padding: 4rpx 10rpx;
}

.game-meta.to-par-over {
  color: #d32f2f;
  background: #ffebee;
}

.game-meta.to-par-under {
  color: #1b7f45;
  background: #e8f5e9;
}

.game-meta.to-par-even {
  color: #5f6b7a;
  background: #eef1f4;
}

.game-meta.to-par-empty {
  color: #9aa4af;
  background: #f4f6f8;
}

.game-players {
  display: flex;
  gap: 16rpx;
}

.game-players text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.game-players text:not(:last-child)::after {
  content: '·';
  margin-left: 16rpx;
}

/* 进行中的比赛卡片 - 简洁白色卡片 */
.ongoing-game-card {
  background: #ffffff;
  border-left: 8rpx solid var(--primary);
}

.ongoing-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.ongoing-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #e8f5e9;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.ongoing-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--primary);
  border-radius: 50%;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.ongoing-text {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--primary);
}

.ongoing-hole {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.ongoing-course {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 14rpx;
}

.ongoing-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.ongoing-meta-item {
  font-size: 23rpx;
  color: var(--text-secondary);
  background: #f1f4f7;
  padding: 6rpx 14rpx;
  border-radius: 18rpx;
}

.ongoing-scores {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 16rpx;
}

.score-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.score-item:last-child {
  border-bottom: none;
}

.score-name {
  font-size: 30rpx;
  color: var(--text-primary);
  flex: 1;
}

.score-to-par {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-right: 30rpx;
}

.score-to-par.under {
  color: var(--primary);
}

.score-to-par.over {
  color: #e53935;
}

.score-total {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 个人数据概览 - 简洁灰色背景 */
.stats-overview-card {
  background: #ffffff;
}

.stats-overview-card .section-title {
  margin-bottom: 24rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.stat-box {
  text-align: center;
  background: #f8f9fa;
  padding: 24rpx 0;
  border-radius: 12rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.stat-box .stat-label {
  font-size: 22rpx;
  color: var(--text-light);
}

/* 底部功能区 */
.footer-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  margin-top: 20rpx;
}

.footer-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 32rpx;
  position: relative;
  z-index: 1;
}

.footer-btn:active {
  opacity: 0.7;
}

.footer-icon {
  font-size: 32rpx;
}

.footer-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.footer-divider {
  width: 2rpx;
  height: 32rpx;
  background: var(--text-light);
  opacity: 0.3;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
  z-index: 1000;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  width: 100%;
  max-height: 80vh;
  padding: 40rpx 30rpx calc(40rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: all 0.3s;
}

.modal.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  font-size: 48rpx;
  color: var(--text-light);
  line-height: 1;
}

.modal-body {
  max-height: 60vh;
  overflow-y: auto;
}

/* 比赛详情弹窗 */
.detail-progress {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
  margin-bottom: 30rpx;
}

.detail-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.detail-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.detail-section {
  margin-bottom: 30rpx;
}

.detail-scores {
  background: var(--bg-gray);
  border-radius: 16rpx;
  padding: 20rpx;
}

.detail-score-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid var(--border);
}

.detail-score-row:last-child {
  border-bottom: none;
}

.player-info-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.player-status {
  font-size: 36rpx;
  font-weight: 700;
}

.player-status.under {
  color: var(--primary);
}

.player-status.over {
  color: #e53935;
}

.continue-btn {
  width: 100%;
  margin-top: 20rpx;
}

/* 数据统计详情 */
.stats-detail-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.stats-detail-item {
  background: var(--bg-gray);
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
}

.stats-detail-num {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.stats-detail-num.under {
  color: var(--primary);
}

.stats-detail-num.over {
  color: #e53935;
}

.stats-detail-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.stats-trend {
  border-top: 1rpx solid var(--border);
  padding-top: 30rpx;
}

.stats-trend-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 20rpx;
}

.trend-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.trend-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.trend-item:last-child {
  border-bottom: none;
}

.trend-date {
  font-size: 24rpx;
  color: var(--text-light);
  width: 100rpx;
}

.trend-course {
  font-size: 28rpx;
  color: var(--text-primary);
  flex: 1;
  margin: 0 20rpx;
}

.trend-score {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}
/* 进行中的比赛 - 个人成绩 */
.ongoing-my-score {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
}

.score-row {
  display: flex;
  align-items: center;
}

.score-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.score-divider {
  width: 2rpx;
  height: 80rpx;
  background: #e0e0e0;
}

.my-score-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.my-score-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.my-to-par {
  font-size: 44rpx;
  font-weight: 700;
}

.my-to-par.under {
  color: var(--primary);
}

.my-to-par.over {
  color: #e53935;
}

.my-total {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.my-estimated {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--primary);
}

.estimated-unit {
  font-size: 24rpx;
  font-weight: 400;
  margin-left: 4rpx;
}

/* 我的数据 - 积极指标 */
.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.stats-arrow {
  font-size: 40rpx;
  color: var(--text-light);
}

.stat-box.positive {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
}

.stat-box.highlight {
  background: linear-gradient(135deg, #fff8e1 0%, #ffecb3 100%);
}

.stat-box.positive .stat-label,
.stat-box.highlight .stat-label {
  color: var(--text-secondary);
  font-weight: 500;
}

/* 新闻卡片 */
.news-card {
  background: #ffffff;
}

.news-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.news-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.news-content {
  flex: 1;
  margin-right: 20rpx;
}

.news-title {
  font-size: 30rpx;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.news-source {
  font-size: 24rpx;
  color: var(--text-light);
}

.news-arrow {
  font-size: 36rpx;
  color: var(--text-light);
}

/* 快速开始卡片 */
.start-card {
  background: linear-gradient(135deg, #2c8f4e 0%, #1b5e20 100%);
  color: white;
}

.start-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
}

.start-info {
  flex: 1;
}

.start-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 8rpx;
}

.start-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.start-btn {
  background: white;
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  line-height: 1.2;
  flex-shrink: 0;
  border: none;
  white-space: nowrap;
}

.start-btn::after {
  border: none;
}

/* 最近比赛列表 */
.recent-games-card {
  padding: 24rpx;
}

.recent-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.recent-title-block {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.recent-section-title {
  margin-bottom: 0;
  line-height: 1.2;
}

.recent-section-subtitle {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8a958d;
  line-height: 1.2;
}

.recent-view-all {
  flex-shrink: 0;
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 600;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(44, 143, 78, 0.1);
}

.recent-game-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.recent-game-item {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 136rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f8faf8;
  border: 1rpx solid #e8f0ea;
  box-sizing: border-box;
}

.recent-game-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 14rpx;
}

.recent-game-info {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.recent-game-name {
  display: block;
  font-size: 29rpx;
  line-height: 1.25;
  color: #26322b;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-game-date {
  display: block;
  font-size: 22rpx;
  line-height: 1.2;
  color: #8b9690;
}

.recent-game-meta-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.recent-game-meta {
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #eef3ef;
  color: #637069;
  font-size: 21rpx;
  font-weight: 500;
  line-height: 1;
  box-sizing: border-box;
}

.recent-game-to-par.to-par-over {
  color: #c24a2d;
  background: #fff0e8;
}

.recent-game-to-par.to-par-under {
  color: #1b7f45;
  background: #e8f5e9;
}

.recent-game-to-par.to-par-even {
  color: #5f6b7a;
  background: #eef1f4;
}

.recent-game-to-par.to-par-empty {
  color: #9aa4af;
  background: #f4f6f8;
}

.recent-game-scorebox {
  width: 112rpx;
  min-width: 112rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e2ece5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.recent-game-score {
  font-size: 36rpx;
  line-height: 1;
  color: var(--primary);
  font-weight: 700;
}

.recent-game-score-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1;
  color: #7e8a82;
  font-weight: 500;
}

/* 骨架屏样式 */
.skeleton-wrapper {
  padding: 30rpx;
}

.skeleton-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.skeleton-title {
  width: 200rpx;
  height: 36rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}

.skeleton-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.skeleton-text {
  height: 28rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 6rpx;
}

.skeleton-text-lg {
  width: 160rpx;
}

.skeleton-text-sm {
  width: 80rpx;
}

.skeleton-grid {
  display: flex;
  gap: 20rpx;
}

.skeleton-box {
  flex: 1;
  height: 100rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 12rpx;
}

.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.skeleton-item {
  height: 80rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 12rpx;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* 首页增长改版 P0/P1 */
.home-hero-card {
  background: linear-gradient(140deg, #123f2b 0%, #1d6b46 55%, #2c8f4e 100%);
  color: #fff;
  overflow: hidden;
}

.hero-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.2);
  margin-bottom: 18rpx;
}

.hero-title {
  display: block;
  font-size: 46rpx;
  line-height: 1.28;
  font-weight: 700;
}

.hero-subtitle {
  display: block;
  margin-top: 14rpx;
  font-size: 27rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.9);
}

.hero-actions {
  margin-top: 26rpx;
}

.hero-primary-btn {
  width: 100%;
  font-weight: 700;
}

.onboarding-card {
  padding-top: 24rpx;
}

.onboarding-steps {
  margin-top: 12rpx;
}

.home-step-item {
