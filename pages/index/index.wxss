}

.benefit-card {
  padding-top: 24rpx;
}

.benefit-grid {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.benefit-item {
  border-radius: 14rpx;
  background: #f8faf8;
