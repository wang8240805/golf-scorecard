}

.home-step-main {
  display: flex;
  flex-direction: column;
}

.home-step-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.home-step-desc {
  margin-top: 6rpx;
  font-size: 25rpx;
  line-height: 1.5;
