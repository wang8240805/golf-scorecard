/* 页面使用全局 .container 类 */

/* 用户卡片 */
.user-card {
  position: relative;
  display: flex;
  align-items: center;
  padding: 40rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  border-radius: 24rpx;
  margin-bottom: 30rpx;
}

/* 头像按钮 wrapper - 官方结构 */
.avatar-wrapper {
  width: 120rpx !important;
  height: 120rpx !important;
  min-width: 120rpx !important;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 30rpx !important;
  margin-left: 0 !important;
  padding: 0 !important;
  background: rgba(255, 255, 255, 0.1);
  flex-shrink: 0 !important;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-wrapper::after {
  border: none !important;
  display: none !important;
}

.user-avatar-image {
  width: 100%;
  height: 100%;
  display: block;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 12rpx;
}

.user-level {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  font-size: 24rpx;
  color: white;
}

.nickname-input {
  display: block;
  width: 100%;
  min-height: 68rpx;
  padding: 14rpx 20rpx;
  background: white;
  border-radius: 12rpx;
  border: 2rpx solid #fff;
  font-size: 28rpx;
  line-height: 1.4;
  box-sizing: border-box;
  color: #333;
}

.nickname-input::placeholder {
  color: #666;
  font-size: 26rpx;
}

/* 透明遮罩按钮，让整个卡片可点击重新选择头像 */
.user-card-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
}

.user-card-overlay::after {
  display: none;
}

/* 统计卡片 */
.stats-card {
  padding: 30rpx 20rpx;
  margin-bottom: 30rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 菜单卡片 */
.menu-card {
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.menu-item:active {
  background: var(--bg-gray);
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(44, 143, 78, 0.1) 0%, rgba(44, 143, 78, 0.05) 100%);
  border-radius: 50%;
  margin-bottom: 16rpx;
}

/* 线性图标 - 与tab栏风格一致 */
.icon-svg {
  position: relative;
  width: 40rpx;
  height: 40rpx;
}

/* 列表图标 */
.icon-list::before {
  content: "";
  position: absolute;
  top: 6rpx;
  left: 4rpx;
  width: 32rpx;
  height: 4rpx;
  background: var(--primary);
  border-radius: 2rpx;
  box-shadow: 0 10rpx 0 var(--primary), 0 20rpx 0 var(--primary);
}

/* 柱状图图标 */
.icon-bar-chart::before {
  content: "";
  position: absolute;
  bottom: 0;
  left: 4rpx;
  width: 8rpx;
  height: 16rpx;
  background: var(--primary);
  border-radius: 2rpx 2rpx 0 0;
}

.icon-bar-chart::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 16rpx;
  width: 8rpx;
  height: 28rpx;
  background: var(--primary);
  border-radius: 2rpx 2rpx 0 0;
  box-shadow: 12rpx 0 0 var(--primary);
}

/* 旗帜图标 */
.icon-flag::before {
  content: "";
  position: absolute;
  bottom: 0;
  left: 4rpx;
  width: 4rpx;
  height: 36rpx;
  background: var(--primary);
  border-radius: 2rpx;
}

.icon-flag::after {
  content: "";
  position: absolute;
  top: 2rpx;
  left: 8rpx;
  width: 24rpx;
  height: 16rpx;
  background: var(--primary);
  border-radius: 0 4rpx 4rpx 0;
  clip-path: polygon(0 0, 100% 50%, 0 100%);
}

/* 用户组图标 */
.icon-users::before {
  content: "";
  position: absolute;
  top: 4rpx;
  left: 10rpx;
  width: 10rpx;
  height: 10rpx;
  border: 3rpx solid var(--primary);
  border-radius: 50%;
  background: transparent;
}

.icon-users::after {
  content: "";
  position: absolute;
  bottom: 2rpx;
  left: 4rpx;
  width: 24rpx;
  height: 12rpx;
  border: 3rpx solid var(--primary);
  border-bottom: none;
  border-radius: 12rpx 12rpx 0 0;
  background: transparent;
}

.menu-text {
  font-size: 24rpx;
  color: var(--text-primary);
}

/* 设置卡片 */
.setting-card {
  padding: 0;
  overflow: hidden;
  margin-bottom: 30rpx;
}

.setting-title {
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  border-bottom: 1rpx solid var(--border-color);
}

.setting-list {
  padding: 0 30rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.setting-icon {
  font-size: 36rpx;
}

/* 设置列表图标 */
.setting-icon-svg {
  position: relative;
  width: 36rpx;
  height: 36rpx;
  margin-right: 20rpx;
}

/* 设置图标（齿轮） */
.icon-settings::before {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 16rpx;
  height: 16rpx;
  border: 3rpx solid var(--text-secondary);
  border-radius: 50%;
  background: transparent;
}

.icon-settings::after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 28rpx;
  height: 28rpx;
  border: 3rpx dotted var(--text-secondary);
  border-radius: 50%;
  background: transparent;
}

/* 消息图标 */
.icon-message::before {
  content: "";
  position: absolute;
  top: 4rpx;
  left: 2rpx;
  width: 32rpx;
  height: 22rpx;
  border: 3rpx solid var(--text-secondary);
  border-radius: 6rpx;
  background: transparent;
}

.icon-message::after {
  content: "";
  position: absolute;
  bottom: 6rpx;
  left: 8rpx;
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-top: 8rpx solid var(--text-secondary);
}

/* 信息图标 */
.icon-info::before {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid var(--text-secondary);
  border-radius: 50%;
  background: transparent;
}

.icon-info::after {
  content: "i";
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 20rpx;
  font-weight: 700;
  font-style: italic;
  color: var(--text-secondary);
  line-height: 1;
}

.setting-text {
  font-size: 30rpx;
  color: var(--text-primary);
}

.setting-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.setting-version {
  font-size: 26rpx;
  color: var(--text-light);
}

.setting-arrow {
  font-size: 32rpx;
  color: var(--text-light);
}

/* 分享按钮 */
.share-btn {
  background: none;
  border: none;
  margin: 0;
  padding: 0;
  width: 100%;
  text-align: left;
  line-height: inherit;
}

.share-btn::after {
  border: none;
}

/* 覆盖Vant Cell的箭头为CSS箭头 */
.van-cell__right-icon {
  position: relative;
  width: 16rpx !important;
  height: 16rpx !important;
  border: 4rpx solid var(--text-light, #999);
  border-left: none !important;
  border-bottom: none !important;
  transform: rotate(45deg);
  margin-right: 8rpx;
}

.van-cell__right-icon::before {
  display: none !important;
}

.van-icon-arrow:before {
  content: "" !important;
}
