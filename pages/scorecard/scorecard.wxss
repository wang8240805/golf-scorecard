/* 页面容器 - flex布局 */
.page-container {
  min-height: 100vh;
  background: var(--bg-gray);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.empty-state {
  flex: 1;
  min-height: 70vh;
  padding: 120rpx 48rpx;
  box-sizing: border-box;
  text-align: center;
}

.empty-scorecard-icon {
  width: 150rpx;
  height: 150rpx;
  border-radius: 42rpx;
  margin-bottom: 32rpx;
  background:
    linear-gradient(90deg, transparent 31%, rgba(255,255,255,0.72) 31%, rgba(255,255,255,0.72) 34%, transparent 34%, transparent 65%, rgba(255,255,255,0.72) 65%, rgba(255,255,255,0.72) 68%, transparent 68%),
    linear-gradient(0deg, transparent 31%, rgba(255,255,255,0.72) 31%, rgba(255,255,255,0.72) 34%, transparent 34%, transparent 65%, rgba(255,255,255,0.72) 65%, rgba(255,255,255,0.72) 68%, transparent 68%),
    linear-gradient(135deg, #2c8f4e 0%, #1b5e20 100%);
  box-shadow: 0 18rpx 40rpx rgba(44, 143, 78, 0.22);
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-top: 0;
}

.empty-subtitle {
  font-size: 27rpx;
  color: var(--text-secondary);
  margin-top: 14rpx;
  line-height: 1.5;
}

.empty-action-btn {
  margin-top: 42rpx;
  width: 320rpx;
  height: 84rpx;
  border-radius: 42rpx;
  font-size: 30rpx;
}

.empty-action-btn::after {
  border: none;
}

/* 可滚动内容区域 - flex自适应 */
.content-area {
  flex: 1;
  padding: 16rpx 16rpx 20rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

/* 底部留白 - 在内容区和按钮之间创建空间 */
.bottom-spacer {
  height: 160rpx;
}

/* 底部操作栏 - sticky定位在页面底部 */
.action-bar-fixed {
  position: sticky;
  bottom: 0;
  left: 0;
  right: 0;
  margin-top: auto;
  padding: 20rpx 30rpx calc(30rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.12);
  z-index: 100;
  display: flex;
  flex-direction: column;
}

.action-bar-fixed .btn {
  width: 100%;
  margin: 0;
}

.btn-large {
  height: 96rpx;
  font-size: 34rpx;
}

.hole-nav {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.course-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
}

.course-info-left {
  display: flex;
  flex-direction: column;
  min-width: 0;
  flex: 1;
}

.course-info-left .section-title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.scorecard-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  flex-wrap: nowrap;
}

.player-card-actions {
  gap: 10rpx;
}

/* 统一按钮体系：避免出现“又宽又瘪”的不一致样式 */
.btn-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-weight: 600;
  line-height: 1;
  white-space: nowrap;
  box-sizing: border-box;
  border: none;
  flex-shrink: 0;
}

.btn-pill::after {
  border: none;
}

.btn-pill:active {
  opacity: 0.9;
  transform: translateY(1rpx);
}

.btn-pill-xs {
  height: 52rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
}

.btn-pill-sm {
  height: 60rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
}

.btn-pill-lg {
  height: 88rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
}

.finish-game-btn {
  background: #f44336;
  color: #fff;
  min-width: 152rpx;
  margin: 0;
}

.action-finish-btn {
  width: 100%;
  min-width: 0;
  height: 92rpx;
  font-size: 32rpx;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-gray);
  border-radius: 50%;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.nav-btn.disabled {
  opacity: 0.4;
}

.nav-btn:active:not(.disabled) {
  background: var(--primary);
  color: white;
}

.hole-meter {
  min-width: 96rpx;
  height: 86rpx;
  border-radius: 18rpx;
  background: #f0f7f2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 0 0 1rpx #d9eadd;
}

.hole-number {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
  min-width: 0;
  text-align: center;
  line-height: 1;
}

.hole-meter-par {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #557063;
  font-weight: 600;
  line-height: 1;
}

.hole-info {
  background: linear-gradient(135deg, #f5f5f5 0%, #e8f5e9 100%);
  padding: 24rpx;
}

/* 紧凑型洞头部 */
.hole-header-compact {
  display: flex;
  align-items: center;
  justify-content: center;
}

.hole-title-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.hole-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.hole-badges {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.hole-badge {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.par-badge {
  background: var(--primary);
  color: #fff;
}

.handicap-badge {
  background: rgba(0, 122, 255, 0.15);
  color: #007aff;
}

.distance-badge {
  background: rgba(255, 149, 0, 0.15);
  color: #ff9500;
}

/* 旧样式兼容 - 保留但不再使用 */
.hole-header {
  text-align: center;
}

.hole-details {
  display: flex;
  justify-content: center;
  gap: 60rpx;
}

.hole-detail {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-label {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 8rpx;
}

.detail-value {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.detail-value.par {
  color: var(--primary);
}

/* AI打法建议 */
.hole-tip {
  display: flex;
  align-items: stretch;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 0;
  background: transparent;
}

.tip-icon {
  width: 72rpx;
  height: auto;
  background: transparent;
  border: 2rpx solid #ccc;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #999;
  flex-shrink: 0;
  min-height: 72rpx;
  letter-spacing: 2rpx;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #555;
  line-height: 1.5;
  padding: 12rpx 16rpx;
  background: rgba(44, 143, 78, 0.08);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
}

.tip-voice {
  width: 72rpx;
  height: auto;
  background: var(--primary);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  flex-shrink: 0;
  min-height: 72rpx;
}

.tip-voice:active {
  transform: scale(0.9);
  opacity: 0.8;
}

.tip-voice.playing {
  background: #ff3b30;
}

.voice-icon {
  width: 0;
  height: 0;
}

.voice-icon.play {
  width: 0;
  height: 0;
  border-left: 16rpx solid #fff;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  margin-left: 2rpx;
}

.voice-icon.stop {
  width: 16rpx;
  height: 16rpx;
  background: #fff;
  border-radius: 3rpx;
}

.score-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--border);
}

.score-row:last-child {
  border-bottom: none;
}

.player-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.player-avatar-sm {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 26rpx;
  font-weight: 600;
}

.score-badge {
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.score-input-group {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.score-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-gray);
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.score-btn:active {
  background: var(--primary);
  color: white;
}

.score-btn.minus {
  color: var(--danger);
}

.score-btn.plus {
  color: var(--primary);
}

.score-input {
  width: 100rpx;
  height: 72rpx;
  text-align: center;
  border: 2rpx solid var(--border);
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.score-input:focus {
  border-color: var(--primary);
}

.score-grid-scroll {
  width: 100%;
  padding-bottom: 10rpx;
  overflow-x: scroll;
  overflow-y: hidden;
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
  background: #f7faf8;
  border-radius: 14rpx;
  box-shadow: inset 0 0 0 1rpx #e7eee9;
}

.score-grid-shell {
  width: 100%;
  overflow: hidden;
  background: #f7faf8;
  border-radius: 14rpx;
  box-shadow: inset 0 0 0 1rpx #e7eee9;
}

.score-grid-fixed-header {
  overflow: hidden;
}

.score-grid-body-scroll {
  width: 100%;
  height: 54vh;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.score-grid-fixed-header .score-grid,
.score-grid-body-scroll .score-grid {
  display: table !important;
  border-collapse: collapse;
  width: 100%;
  table-layout: fixed;
}

/* 固定表头：球员行保持绿色背景，避免被通用白底覆盖 */
.score-grid-fixed-header .score-grid.transposed .grid-row.header .grid-cell {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary-dark);
}

.score-grid-fixed-header .score-grid.transposed .grid-row.header .player-mini-name {
  color: #fff;
  text-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.3);
}

/* 表格右侧留白，确保最后一列完整显示 */
.score-grid-scroll .score-grid {
  display: table !important;
  border-collapse: collapse;
  width: 100%;
}

.score-grid {
  display: table !important;
  border-collapse: collapse;
  width: 100%;
}

.grid-row {
  display: table-row;
}

.grid-row.striped {
  background: rgba(0, 0, 0, 0.02);
}

.grid-cell {
  display: table-cell;
  padding: 20rpx 16rpx;
  text-align: center;
  border: 2rpx solid var(--border);
  white-space: nowrap;
  font-size: 26rpx;
  min-width: 60rpx;
}

.grid-row.header .grid-cell {
  background: var(--primary);
  color: white;
  font-weight: 600;
  border-color: var(--primary-dark);
}

/* 总杆数行样式（替代原来的标准杆行） */
.grid-row.total-row {
  background: #e8f5e9;
  position: sticky;
  top: 0;
  z-index: 2;
}

.grid-row.total-row .grid-cell {
  background: transparent;
  color: var(--primary-dark);
  font-weight: 600;
  padding: 8rpx 10rpx;
}

.grid-row.total-row .label-cell {
  background: #e8f5e9;
  font-weight: 700;
}

.player-cell {
  min-width: 100rpx;
  position: sticky;
  left: 0;
  background: white;
  z-index: 1;
}

.grid-row.header .player-cell,
.grid-row.total-row .player-cell {
  z-index: 1;
}

.player-mini {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 22rpx;
  font-weight: 600;
  margin: 0 auto;
}

.hole-cell.current {
  background: rgba(44, 143, 78, 0.15);
  font-weight: 600;
}

.hole-cell.birdie {
  background: #2196f3;
  color: white;
}

.hole-cell.par {
  background: var(--primary-light);
  color: white;
}

.hole-cell.bogey {
  background: #ff9800;
  color: white;
}

.hole-cell.double-bogey {
  background: #f44336;
  color: white;
}

.hole-cell.eagle {
  background: #9c27b0;
  color: white;
}

.total-cell {
  font-weight: 700;
  min-width: 80rpx;
  position: sticky;
  right: 0;
  background: white;
}

.total-cell.under {
  color: var(--primary);
}

.total-cell.over {
  color: var(--danger);
}

.total-cell.even {
  color: var(--text-secondary);
}

/* 转置记分卡中的总杆行单元格样式 */
/* 杆数行整体高度和其他洞行一致 */
.score-grid.transposed .total-row {
  height: 76rpx;
}

.score-grid.transposed .total-row .grid-cell {
  height: 76rpx;
  padding: 8rpx 10rpx !important;
  vertical-align: middle !important;
  line-height: 60rpx !important;
}

.score-grid.transposed .total-row .grid-cell.total-cell {
  background: transparent !important;
  position: static;
  font-weight: 700;
}

.total-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
}

.total-main {
  font-size: 32rpx;
  font-weight: 700;
  color: #000;
  line-height: 1.2;
}

.total-diff {
  font-size: 20rpx;
  font-weight: 500;
  line-height: 1;
}

.total-diff.under {
  color: #ff3b30;
}

.total-diff.over {
  color: #ff9500;
}

.total-diff.even {
  color: var(--primary);
}

/* 玩法选择区域 */
.mode-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  margin-top: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.mode-info {
  flex: 1;
}

.mode-label {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 4rpx;
}

.mode-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--primary);
  display: block;
}

.mode-desc {
  font-size: 24rpx;
  color: #666;
  margin-top: 4rpx;
  display: block;
}

.mode-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.mode-change {
  font-size: 24rpx;
  color: var(--primary);
  padding: 8rpx 16rpx;
  background: white;
  border-radius: 20rpx;
  border: 1rpx solid var(--primary);
}

/* 完成比赛按钮（玩法卡片中） */
.finish-btn-small {
  background: #2c8f4e;
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
  border: none;
  line-height: 1;
}

.finish-btn-small:active {
  opacity: 0.8;
  transform: scale(0.95);
}

/* 领先者区域 */
.leader-section {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 20rpx;
  margin-top: 16rpx;
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  border-radius: 12rpx;
}

.leader-label {
  font-size: 22rpx;
  color: var(--primary-dark);
  font-weight: 500;
}

.leader-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.leader-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 24rpx;
  font-weight: 600;
}

.leader-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
}

.leader-score {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
}

/* 玩法选择弹窗 */
.mode-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
  z-index: 1000;
  padding: 40rpx;
}

.mode-modal.show {
  opacity: 1;
  visibility: visible;
}

.mode-modal-content {
  background: #fff;
  border-radius: 24rpx;
  width: 100%;
  max-height: 70vh;
  overflow: hidden;
  transform: translateY(50rpx);
  transition: all 0.3s;
}

.mode-modal.show .mode-modal-content {
  transform: translateY(0);
}

.mode-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.mode-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.mode-modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  padding: 0 10rpx;
}

.mode-modal-body {
  padding: 20rpx;
  max-height: 50vh;
  overflow-y: auto;
}

.mode-option {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  background: #f5f5f5;
  border: 2rpx solid transparent;
}

.mode-option.selected {
  background: #e8f5e9;
  border-color: var(--primary);
}

.mode-option-icon {
  width: 64rpx;
  height: 64rpx;
  background: var(--primary);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 20rpx;
}

.mode-option-info {
  flex: 1;
}

.mode-option-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.mode-option-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
}

.mode-option-check {
  font-size: 32rpx;
  color: var(--primary);
  font-weight: 600;
}

/* 弹窗内的让洞设置 */
.handicap-in-modal {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #e5e5ea;
}

.handicap-modal-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  text-align: center;
}

/* 成绩录入区域新样式 */
.card {
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(31, 52, 38, 0.06);
}

.header-card {
  padding: 22rpx;
  background: linear-gradient(135deg, #ffffff 0%, #eef8f1 100%);
  border: 1rpx solid #e5f0e8;
}

.card:last-child {
  margin-bottom: 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 0 8rpx 0;
  min-height: 56rpx;
  gap: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 56rpx;
}

.section-title-block {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.section-title-block .section-title {
  line-height: 1.2;
}

.section-subtitle {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #748171;
  font-weight: 500;
  line-height: 1.2;
}

.add-player-btn {
  gap: 6rpx;
  min-width: 120rpx;
  background: linear-gradient(135deg, #2c8f4e 0%, #1e6b3a 100%);
  margin: 0;
  box-shadow: 0 3rpx 10rpx rgba(44, 143, 78, 0.3);
}

.add-player-icon {
  font-size: 26rpx;
  color: #fff;
  font-weight: 700;
}

.add-player-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

.score-display {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: var(--bg-gray);
  border-radius: 12rpx;
  min-width: 120rpx;
  justify-content: center;
}

.score-main {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.strokes {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.putts {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.score-placeholder {
  display: flex;
  align-items: center;
}

.placeholder-text {
  font-size: 28rpx;
  color: var(--text-light);
}

/* 转置记分卡样式 */
.score-grid.transposed {
  display: table !important;
  border-collapse: collapse;
  width: 100%;
  table-layout: fixed;
}

.score-grid.transposed .grid-row {
  display: table-row;
}

.score-grid.transposed .grid-cell {
  display: table-cell;
  padding: 10rpx 12rpx;
  text-align: center;
  border: 1rpx solid #e6ede8;
  min-width: 44rpx;
  vertical-align: middle;
  background: #fff;
}

.score-grid.transposed .label-cell {
  min-width: 80rpx;
  position: sticky;
  left: 0;
  background: white;
  z-index: 1;
  font-weight: 500;
}

.score-grid.transposed .grid-row.header .label-cell {
  background: var(--primary);
  color: white;
}

/* 固定表头结构中不再依赖 sticky，保留类名兼容旧结构 */
.score-grid.transposed .sticky-header-row {
  position: static;
  top: 0;
  z-index: 12;
}

.score-grid.transposed .sticky-header-row .grid-cell {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary-dark);
}

.score-grid.transposed .sticky-total-row {
  position: static;
  top: 84rpx;
  z-index: 11;
}

.score-grid.transposed .sticky-total-row .grid-cell {
  background: #e8f5e9;
}

.score-grid.transposed .sticky-header-row .label-cell {
  z-index: 14;
}

.score-grid.transposed .sticky-total-row .label-cell {
  z-index: 13;
}

.score-grid.transposed .grid-cell.hole-label {
  display: flex !important;
  flex-direction: column !important;
  align-items: center;
  gap: 4rpx;
  vertical-align: middle;
  min-height: 72rpx;
  justify-content: center;
}

.score-grid.transposed .hole-num {
  font-size: 28rpx;
  font-weight: 600;
}

.score-grid.transposed .hole-par {
  font-size: 20rpx;
  color: var(--text-light);
}

.score-grid.transposed .player-cell {
  min-width: 104rpx;
}

.player-mini-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  min-height: 82rpx;
  justify-content: center;
}

.player-mini {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 22rpx;
  font-weight: 600;
  margin: 0 auto;
}

.player-mini-name {
  font-size: 20rpx;
  color: #f4fff8;
  font-weight: 600;
  max-width: 90rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.2;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

.score-grid.transposed .current-row {
  background: rgba(44, 143, 78, 0.1);
}

.score-grid.transposed .current-row .grid-cell {
  background: #f0f8f2;
}

.score-grid.transposed .current-row .hole-label {
  background: #2c8f4e;
  color: #fff;
}

.score-grid.transposed .current-row .hole-par {
  color: rgba(255, 255, 255, 0.86);
}

.score-grid.transposed .cell-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}

.score-grid.transposed .cell-content .stroke-count {
  line-height: 1.1;
  margin-bottom: 2rpx;
}

.score-grid.transposed .cell-content .putt-count {
  line-height: 1.1;
}

/* 记分格可点击 */
.score-grid.transposed .grid-cell[bindtap] {
  cursor: pointer;
  min-height: 72rpx;
}

.score-grid.transposed .grid-cell[bindtap]:active {
  opacity: 0.7;
  background: rgba(0, 0, 0, 0.05);
}

.stroke-count {
  font-size: 28rpx;
  font-weight: 600;
}

.putt-count {
  font-size: 20rpx;
  color: var(--text-light);
}

/* 差点显示样式 */
.score-to-par {
  font-size: 28rpx;
  font-weight: 600;
  display: inline-flex;
  min-width: 52rpx;
  min-height: 52rpx;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
}

.to-par-under {
  color: #ff3b30;
}

.to-par-over {
  color: #ff9500;
}

.to-par-even {
  color: var(--primary);
}

.total-content {
  display: block;
  text-align: center;
}

.total-putts {
  font-size: 20rpx;
  color: var(--text-light);
}

.par-value {
  font-size: 24rpx;
  color: var(--primary);
}

/* 成绩录入弹窗 - Apple Watch 风格 */
.score-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
  z-index: 1000;
}

.score-modal.show {
  opacity: 1;
  visibility: visible;
}

.score-modal-content {
  background: #1c1c1e;
  border-radius: 40rpx 40rpx 0 0;
  width: 100%;
  max-height: 90vh;
  overflow: hidden;
  transform: translateY(100%);
  transition: all 0.3s ease-out;
  display: flex;
  flex-direction: column;
}

.score-modal-content.apple-style {
  background: #f2f2f7;
}

.score-modal.show .score-modal-content {
  transform: translateY(0);
}

.score-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 34rpx;
  background: white;
  border-bottom: 1rpx solid #e5e5ea;
  gap: 20rpx;
}

.score-title-stack,
.modal-title-stack {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.score-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #000;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.score-modal-subtitle,
.modal-subtitle {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #687583;
  font-weight: 500;
}

.score-modal-close {
  font-size: 48rpx;
  color: #8e8e93;
  line-height: 1;
  padding: 0 10rpx;
  flex-shrink: 0;
}

.score-modal-body {
  padding: 28rpx 28rpx calc(34rpx + env(safe-area-inset-bottom));
  background: #f2f2f7;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  flex: 1;
}

.entry-mode-switch {
  display: flex;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.entry-mode-switch.compact {
  margin-bottom: 14rpx;
}

.entry-mode-chip {
  flex: 1;
  min-height: 68rpx;
  border-radius: 16rpx;
  border: 1rpx solid #d9e4db;
  background: #ffffff;
  color: #51606d;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 14rpx;
  box-sizing: border-box;
}

.entry-mode-chip.active {
  background: #2c8f4e;
  border-color: #2c8f4e;
  color: #ffffff;
}

.entry-mode-title {
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.15;
}

.entry-mode-note {
  margin-top: 4rpx;
  font-size: 19rpx;
  font-weight: 500;
  line-height: 1.15;
  opacity: 0.86;
}

/* 步进式录入 */
.stepper-panel {
  margin-bottom: 30rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx 24rpx;
  box-shadow: inset 0 0 0 1rpx #edf2ee;
}

.stepper-row {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  margin-bottom: 24rpx;
  gap: 12rpx;
}

.stepper-row:last-of-type {
  margin-bottom: 16rpx;
}

.stepper-label {
  min-width: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #4b5563;
  line-height: 1.2;
  text-align: center;
}

.stepper-control {
  display: flex;
  align-items: center;
  gap: 14rpx;
  justify-content: center;
  width: 100%;
}

.stepper-btn {
  width: 86rpx;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d7e4db;
  background: #fff;
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 700;
  padding: 0;
  margin: 0;
  min-width: 0;
  flex: 0 0 86rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  line-height: 1 !important;
}

.stepper-btn::after {
  border: none;
}

.stepper-btn.meter {
  background: #f3f7f4;
  border-color: #d9e6dd;
  font-size: 40rpx;
  font-weight: 600;
  flex-basis: 92rpx;
  width: 92rpx;
}

.stepper-btn.meter.plus {
  color: #1a7f45;
}

.stepper-btn.meter.minus {
  color: #8a4b1f;
}

.stepper-value {
  min-width: 104rpx;
  height: 70rpx;
  border-radius: 14rpx;
  background: #f4f8f5;
  color: #111827;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 0 12rpx;
}

.stepper-value.large {
  min-width: 158rpx;
  font-size: 52rpx;
  height: 88rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #f6fbf7 0%, #edf7f0 100%);
}

.stepper-row.score .stepper-control {
  gap: 16rpx;
}

.stepper-row.putt {
  margin-bottom: 18rpx;
}

.stepper-summary {
  font-size: 24rpx;
  color: #4c5c6a;
  background: #f2f6f4;
  border-radius: 12rpx;
  padding: 14rpx 18rpx;
}

.quick-diff-controls {
  margin-top: 14rpx;
  gap: 12rpx;
}

.quick-diff-btn {
  flex: 1;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d9e4db;
  background: #fff;
  color: #2f3842;
  font-size: 26rpx;
  font-weight: 600;
  padding: 0;
}

/* 自定义输入框 */
.score-option.custom {
  background: #f2f2f7;
  border: 2rpx dashed #c7c7cc;
}

.score-option.custom.selected {
  background: #e5e5ea;
  border-color: #007aff;
}

.custom-input-wrapper {
  margin-top: 20rpx;
  padding: 20rpx;
  background: white;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.custom-input-label {
  font-size: 28rpx;
  color: #000;
  font-weight: 500;
}

.custom-input {
  flex: 1;
  height: 72rpx;
  border: 2rpx solid #e5e5ea;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  text-align: center;
  font-weight: 600;
  color: #000;
}

.custom-input:focus {
  border-color: #007aff;
}

/* 高级记录折叠区 */
.advanced-section {
  background: white;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
}

.advanced-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #f8f8f8;
}

.advanced-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #000;
}

.advanced-toggle {
  font-size: 24rpx;
  color: #007aff;
}

.advanced-content {
  padding: 20rpx 30rpx;
}

.stat-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e5e5ea;
}

.stat-row:last-child {
  border-bottom: none;
}

.stat-name {
  font-size: 28rpx;
  color: #000;
  width: 140rpx;
  flex-shrink: 0;
}

.stat-control {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stat-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 300;
  background: #e5e5ea;
  color: #007aff;
}

.stat-btn:active {
  background: #d1d1d6;
}

.stat-value {
  font-size: 28rpx;
  color: #000;
  min-width: 60rpx;
  text-align: center;
  font-weight: 500;
}

/* 是/否切换按钮 */
.stat-toggle {
  display: flex;
  align-items: center;
  background: #f2f2f7;
  border-radius: 8rpx;
  padding: 4rpx;
}

.toggle-btn {
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 6rpx;
  background: transparent;
  transition: all 0.2s;
}

.toggle-btn:active {
  opacity: 0.7;
}

/* 选中的"是"按钮 - 绿色 */
.toggle-yes.on {
  background: #2c8f4e;
  color: #fff;
}

/* 选中的"否"按钮 - 红色 */
.toggle-no.on {
  background: #ff3b30;
  color: #fff;
}

.simple-confirm {
  height: 90rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
}

/* 记分卡中的罚杆指示 */
.penalty-indicator {
  font-size: 18rpx;
  color: #ff3b30;
  font-weight: 600;
}

.total-detail {
  font-size: 20rpx;
  color: var(--text-light);
}

.confirm-btn {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.confirm-btn.apple-confirm {
  height: 100rpx;
  border-radius: 16rpx;
  font-size: 34rpx;
  font-weight: 600;
}

/* 添加选手弹窗 */
.wx-contact-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 30rpx;
  background: #2c8f4e !important;
  color: #fff !important;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  border: none !important;
}

.wx-contact-btn text {
  font-size: 30rpx;
  font-weight: 500;
  color: #fff !important;
}

.wx-icon {
  font-size: 36rpx;
}

.divider {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 30rpx 0;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background: var(--border);
}

.divider-text {
  font-size: 24rpx;
  color: var(--text-light);
}

.player-name-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  margin-bottom: 30rpx;
  box-sizing: border-box;
}

.player-name-input:focus {
  border-color: var(--primary);
}

/* 让洞设置弹窗 */
.handicap-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 24rpx;
  text-align: center;
}

.handicap-player-list {
  margin-bottom: 30rpx;
}

.handicap-player-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e5e5ea;
}

.handicap-player-item:last-child {
  border-bottom: none;
}

.handicap-player-item.selected {
  background: #e8f5e9;
  margin: 0 -20rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  border-bottom: none;
}

.handicap-player-item.selected + .handicap-player-item {
  border-top: 1rpx solid #e5e5ea;
}

.handicap-player-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.handicap-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 26rpx;
  font-weight: 600;
}

.handicap-name {
  font-size: 30rpx;
  color: #333;
}

.handicap-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.handicap-value {
  font-size: 32rpx;
  color: #000;
  font-weight: 600;
  min-width: 40rpx;
  text-align: center;
}

.handicap-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  background: #e5e5ea;
  color: #007aff;
}

.handicap-btn:active {
  background: #d1d1d6;
}

/* 比洞赛让洞入口 */
.handicap-entry {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  border-radius: 12rpx;
}

.handicap-entry-label {
  font-size: 24rpx;
  color: var(--primary-dark);
  font-weight: 500;
  flex-shrink: 0;
}

.handicap-players {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.handicap-player-tag {
  font-size: 22rpx;
  color: var(--primary);
  background: rgba(255, 255, 255, 0.8);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.handicap-entry-arrow {
  font-size: 32rpx;
  color: var(--primary);
  font-weight: 300;
}

/* ========== 语音输入按钮 ========== */

/* 语音使用提示 */
.voice-hint {
  text-align: center;
  padding: 8rpx 0;
  margin: 0 24rpx;
}

.voice-hint-text {
  display: block;
  font-size: 22rpx;
  color: #888;
  background: #f5f5f5;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  line-height: 1.5;
  white-space: normal;
}

/* 实时语音识别文字显示 */
.voice-realtime-text {
  text-align: center;
  padding: 16rpx 24rpx;
  margin: 0 24rpx 16rpx;
  background: #e8f5e9;
  border-radius: 16rpx;
  border: 2rpx solid #2c8f4e;
  animation: fadeIn 0.2s ease;
}

.voice-realtime-label {
  font-size: 24rpx;
  color: #2c8f4e;
  font-weight: 500;
  margin-right: 8rpx;
}

.voice-realtime-content {
  font-size: 28rpx;
  color: #1b5e20;
  font-weight: 600;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 语音按钮 */
.voice-btn {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #2c8f4e 0%, #1b5e20 100%);
  border-radius: 20rpx;
  transition: all 0.2s;
  box-shadow: 0 8rpx 20rpx rgba(44, 143, 78, 0.3);
}

.voice-btn.recording {
  background: linear-gradient(135deg, #e53935 0%, #c62828 100%);
  box-shadow: 0 8rpx 20rpx rgba(229, 57, 53, 0.3);
}

.voice-btn:active {
  transform: scale(0.98);
}

.voice-btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 28rpx 0;
  position: relative;
  z-index: 2;
}

.voice-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.voice-icon-text {
  font-size: 40rpx;
  line-height: 1;
}

.voice-btn-text {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.voice-title {
  font-size: 34rpx;
  color: white;
  font-weight: 600;
  line-height: 1.3;
}

.voice-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
