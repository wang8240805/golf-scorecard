}

.par-value-btn.selected .par-value-num {
  color: #2c8f4e;
}

.par-value-tag {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.par-hole-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  justify-content: center;
}

.par-hole-item {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  color: #666;
}

.par-hole-item.current {
  background: #2c8f4e;
  color: #fff;
}

.par-hole-item.filled {
  background: #e8f5e9;
  color: #2c8f4e;
}

.par-hole-item.current.filled {
  background: #2c8f4e;
  color: #fff;
}

/* 二维码在邀请弹窗中的样式 */
.qrcode-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 16rpx;
}

.qrcode-tips {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  line-height: 1.5;
}

.qrcode-image {
  width: 360rpx;
  height: 360rpx;
  margin: 16rpx 0;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.qrcode-wrapper .qrcode-tips:last-child {
  color: #2c8f4e;
  font-weight: 500;
}

/* ========== 待确认成绩样式 ========== */

/* 待确认提示横幅 */
.pending-confirmation-banner {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  margin: 16rpx;
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
  border-radius: 16rpx;
  border: 1rpx solid #ffcc80;
}

.pending-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.pending-text {
  flex: 1;
  font-size: 28rpx;
  color: #e65100;
  font-weight: 500;
}

.pending-action {
  font-size: 24rpx;
  color: #ff9800;
}

/* 记分卡格子待确认标记 */
.grid-cell.pending-confirm {
  background: #fff8e1 !important;
  border: 2rpx dashed #ff9800 !important;
}

.pending-indicator {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  font-size: 18rpx;
  opacity: 0.8;
}

/* 待确认成绩弹窗 */
.pending-modal {
  max-height: 70vh;
}

.pending-list {
  padding: 0 8rpx;
}

.pending-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 16rpx;
  margin-bottom: 16rpx;
  background: #fafafa;
  border-radius: 12rpx;
  border: 1rpx solid #eee;
}

.pending-item-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.pending-hole {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.pending-strokes {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c8f4e;
}

.pending-modifier {
  font-size: 22rpx;
  color: #999;
}

.pending-item-actions {
  display: flex;
  gap: 16rpx;
}

.pending-btn {
  min-width: 96rpx;
}

.pending-btn.confirm {
  background: #2c8f4e;
  color: #fff;
}

.pending-btn.confirm:active {
  background: #237a41;
}

.pending-btn.reject {
  background: #fff;
  color: #f44336;
  border: 1rpx solid #f44336;
}

.pending-btn.reject:active {
  background: #ffebee;
}

.pending-tips {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}
