/* 页面容器 */
.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.select-mode-tip {
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #f4faf6 0%, #ebf6ef 100%);
}

.tip-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f3a2a;
}

.tip-desc {
  display: block;
  font-size: 24rpx;
  color: #6f8a78;
  margin-top: 6rpx;
}

.tip-steps {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.tip-step {
  font-size: 24rpx;
  color: #4b6656;
  line-height: 1.5;
}

.tip-add-btn {
  margin-top: 14rpx;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 30rpx;
  background: #2c8f4e;
  color: #fff;
  font-size: 24rpx;
  padding: 0 22rpx;
}

.tip-add-btn::after {
  border: none;
}

/* 城市头部 */
.city-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #2c8f4e 0%, #1b5e20 100%);
  border-radius: 16rpx;
}

.city-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.city-count {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 搜索框 */
.search-card {
  margin-bottom: 20rpx;
}
.search-box {
  display: flex;
  align-items: center;
  background: var(--bg-gray);
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  gap: 12rpx;
}
.search-icon {
  width: 28rpx;
  height: 28rpx;
  flex: 0 0 28rpx;
  border: 4rpx solid #7a8a80;
  border-radius: 50%;
  box-sizing: border-box;
  position: relative;
}

.search-icon::after {
  content: "";
  position: absolute;
  width: 12rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: #7a8a80;
  right: -10rpx;
  bottom: -5rpx;
  transform: rotate(45deg);
}
.search-input {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: var(--text-primary);
}
.clear-icon {
  font-size: 32rpx;
  color: var(--text-secondary);
  padding: 0 8rpx;
}

.search-online-btn {
  flex: 0 0 132rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0;
  border-radius: 28rpx;
  background: #eaf3ff;
  color: #1559c0;
  border: none;
  font-size: 23rpx;
  margin: 0;
  white-space: nowrap;
}

.search-online-btn::after {
  border: none;
}

/* 工具栏样式 */
.toolbar-card {
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}
.toolbar-actions {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}
.toolbar-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  background: var(--bg-gray);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  border: none;
}
.toolbar-btn.active {
  background: var(--primary);
  color: white;
}
.toolbar-btn::after {
  border: none;
}

.add-course-btn {
  background: #e8f5e9;
  color: #1b5e20;
}

/* 球场列表 */
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.text-small {
  font-size: 26rpx;
}

.text-primary {
  color: var(--primary);
}

.course-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.course-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  background: var(--bg-gray);
  border-radius: 18rpx;
}

.course-item.selected {
  border: 2rpx solid #2c8f4e;
  background: #f4faf6;
}

.course-info {
  flex: 1;
  min-width: 0;
  padding-right: 12rpx;
}

.course-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.course-name {
  flex: 1;
  min-width: 0;
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.35;
}

.course-tag {
  font-size: 20rpx;
  color: var(--primary);
  background: rgba(44, 143, 78, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.course-tag.favorite-tag {
  color: #e53935;
  background: rgba(229, 57, 53, 0.1);
}

.course-tag.selected-tag {
  color: #1f7d43;
  background: rgba(44, 143, 78, 0.12);
}

.course-detail {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.course-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.play-count {
  color: var(--primary);
}

.play-count.new-course {
  color: var(--text-secondary);
}

.course-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  flex-shrink: 0;
  margin-left: 12rpx;
  width: 92rpx;
}

.action-icon {
  font-size: 36rpx;
  padding: 8rpx;
}

.quick-select-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 44rpx;
  width: 92rpx;
  border: none;
  border-radius: 22rpx;
  background: #2c8f4e;
  color: #fff;
  font-size: 22rpx;
  line-height: 1;
  padding: 0;
  margin: 0;
  white-space: nowrap;
  flex: none;
}

/* 空状态 */
.empty-card {
  padding: 80rpx 0;
}
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.empty-add-btn {
  margin-top: 18rpx;
  min-width: 260rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 30rpx;
  background: #2c8f4e;
  color: #fff;
  font-size: 24rpx;
  padding: 0 26rpx;
}

.empty-add-btn::after {
  border: none;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}
.modal.show {
  opacity: 1;
  visibility: visible;
}
.modal-content {
  width: 85%;
  max-height: 80vh;
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  transform: translateY(50rpx);
  transition: transform 0.3s ease;
}
.modal.show .modal-content {
  transform: translateY(0);
}
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border);
}
.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.modal-close {
  font-size: 40rpx;
  color: var(--text-secondary);
  line-height: 1;
}
.modal-body {
  max-height: 60vh;
  padding: 30rpx;
}

.add-course-guide {
  background: #f3f9f5;
  border-radius: 12rpx;
  padding: 16rpx 18rpx;
  margin-bottom: 20rpx;
}

.add-course-guide-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1f3a2a;
  margin-bottom: 6rpx;
}

.add-course-guide-step {
  display: block;
  font-size: 24rpx;
  color: #4b6656;
  line-height: 1.6;
}

.form-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.fill-city-btn {
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 24rpx;
  padding: 0 16rpx;
  font-size: 22rpx;
  color: #1b5e20;
  background: #e8f5e9;
  border: none;
}

.fill-city-btn::after {
  border: none;
}

.form-input-lg {
  height: 76rpx;
  line-height: 76rpx;
  font-size: 30rpx;
  padding: 0 18rpx;
}

.sample-name-wrap {
  margin-top: 12rpx;
}

.sample-name-title {
  display: block;
  font-size: 22rpx;
  color: #6f8a78;
  margin-bottom: 8rpx;
}

.sample-name-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.sample-name-chip {
  max-width: 100%;
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 26rpx;
  padding: 0 16rpx;
  font-size: 22rpx;
  color: #1b5e20;
  background: #eef8f1;
  border: 1rpx solid #d6eedd;
  white-space: nowrap;
}

.sample-name-chip::after {
  border: none;
}

.add-course-cancel-btn,
.add-course-confirm-btn {
  min-height: 84rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
}
.detail-stats {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 0;
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid var(--border);
}
.detail-stat {
  text-align: center;
}
.detail-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--primary);
  display: block;
  margin-bottom: 8rpx;
}
.detail-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}
.holes-detail {
  padding: 20rpx 0;
}
.holes-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  display: block;
}
.holes-table {
  background: var(--bg-gray);
  border-radius: 12rpx;
  overflow: hidden;
}
.holes-row {
  display: flex;
  padding: 20rpx;
  border-bottom: 1rpx solid var(--border);
}
.holes-row:last-child {
  border-bottom: none;
}
.holes-header-row {
  background: rgba(44, 143, 78, 0.1);
}
.hole-cell {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 弹窗底部按钮 */
.modal-footer {
  padding: 30rpx;
  border-top: 1rpx solid var(--border);
  background: #f9f9f9;
}

.btn-block {
  width: 100%;
}

.btn-primary {
  background: var(--primary);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary:active {
  background: #1b5e20;
}

.btn-secondary {
  background: #f0f0f0;
  color: #555;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-secondary:active {
  background: #e5e5e5;
}

.add-course-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.form-label {
  font-size: 26rpx;
  color: #555;
}

.form-input {
  background: var(--bg-gray);
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 30rpx;
}

.form-tip {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
}

.modal-footer .btn {
  flex: 1;
}
