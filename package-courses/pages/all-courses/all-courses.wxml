<view class="container">
  <!-- 搜索框 -->
  <view class="card search-card">
    <view class="search-box">
      <text class="search-icon"></text>
      <input
        class="search-input"
        type="text"
        placeholder="搜索{{userCity}}的球场"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
      />
      <text class="clear-icon" wx:if="{{searchKeyword}}" bindtap="clearSearch">×</text>
    </view>
    <view class="search-helper" wx:if="{{searchKeyword}}">
      <text class="search-helper-text">{{searchHintText}}</text>
      <button class="search-online-btn" bindtap="searchOnlineByKeyword" loading="{{onlineSyncing}}" disabled="{{onlineSyncing}}">地图补全</button>
    </view>
  </view>

  <!-- 工具栏 -->
  <view class="card toolbar-card">
    <view class="province-filter-row" wx:if="{{fromNewGame && provinceQuickFilters.length > 0}}">
      <view class="province-filter-list">
        <view
          wx:for="{{provinceQuickFilters}}"
          wx:key="value"
          class="province-filter-chip {{selectedProvinceFilter === item.value ? 'active' : ''}}"
          bindtap="selectProvinceFilter"
          data-value="{{item.value}}"
        >
          {{item.label}}
        </view>
      </view>
    </view>
    <view class="toolbar-actions" wx:if="{{!fromNewGame}}">
      <button class="toolbar-btn {{showFavoritesOnly ? 'active' : ''}}" bindtap="toggleFavoritesOnly" wx:if="{{!fromNewGame}}">
        {{showFavoritesOnly ? '显示全部' : '仅看收藏'}}
      </button>
      <button class="toolbar-btn" bindtap="toggleSortBy">
        排序: {{sortBy === 'playCount' ? '按次数' : sortBy === 'name' ? '按名称' : '离我最近'}}
      </button>
      <button class="toolbar-btn add-course-btn" bindtap="openAddCourseModal" wx:if="{{!fromNewGame}}">
        手动新增
      </button>
      <button class="toolbar-btn map-course-btn" bindtap="searchOnlineByKeyword" loading="{{onlineSyncing}}" disabled="{{onlineSyncing}}" wx:if="{{!fromNewGame && searchKeyword}}">
        地图补全
      </button>
    </view>
  </view>

  <!-- 球场列表 -->
  <view class="card" wx:if="{{filteredCourses.length > 0}}">
    <view class="section-title flex-between">
      <text wx:if="{{searchKeyword}}">搜索结果 ({{filteredCourses.length}})</text>
      <text wx:elif="{{showFavoritesOnly}}">我的收藏 ({{filteredCourses.length}})</text>
      <text wx:else>全部球场 ({{filteredCourses.length}})</text>
    </view>
    <view class="course-list">
      <view class="course-item {{fromNewGame && currentCourseId === item.id ? 'selected' : ''}}" wx:for="{{filteredCourses}}" wx:key="id" bindtap="onCourseTap" data-course="{{item}}">
        <view class="course-info">
          <view class="course-header">
            <text class="course-name">{{item.name}}</text>
            <view class="course-tag favorite-tag" wx:if="{{item.isFavorite && !fromNewGame}}">已收藏</view>
            <view class="course-tag selected-tag" wx:if="{{fromNewGame && currentCourseId === item.id}}">当前选择</view>
          </view>
          <text class="course-detail">{{item.holes ? item.holes.length : 18}}洞 · 标准杆{{item.totalPar || 72}}</text>
          <view class="course-meta">
            <text class="course-location" wx:if="{{item.location}}">{{item.location}}</text>
            <text class="play-count" wx:if="{{item.playCount > 0}}">打过 {{item.playCount}} 次</text>
            <text class="play-count new-course" wx:if="{{item.playCount === 0}}">未打过</text>
            <text class="course-data-status missing" wx:if="{{!item.holes || item.holes.length === 0}}">需校准par</text>
          </view>
        </view>
        <view class="course-actions" wx:if="{{!fromNewGame}}">
          <view class="action-icon favorite-icon" wx:if="{{!fromNewGame}}" catchtap="toggleFavorite" data-course-id="{{item.id}}">
            {{item.isFavorite ? '❤️' : '🤍'}}
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="card empty-card" wx:if="{{filteredCourses.length === 0}}">
    <view class="empty-state">
      <view class="empty-icon">⛳</view>
      <text class="empty-text">{{searchKeyword ? '没有找到匹配的球场' : showFavoritesOnly ? '还没有收藏任何球场' : '暂无球场数据'}}</text>
      <view class="empty-action-row" wx:if="{{fromNewGame}}">
        <button class="empty-add-btn" bindtap="openAddCourseModal">手动新增</button>
      </view>
      <button class="empty-map-btn" wx:if="{{searchKeyword}}" bindtap="searchOnlineByKeyword" loading="{{onlineSyncing}}" disabled="{{onlineSyncing}}">用地图补全名称地址</button>
    </view>
  </view>

  <!-- 全部省份选择 -->
  <view class="modal {{showProvincePicker ? 'show' : ''}}" wx:if="{{showProvincePicker}}" bindtap="closeProvincePicker">
    <view class="modal-content province-picker-content" catchtap="preventHide">
      <view class="modal-header">
        <text class="modal-title">选择省份</text>
        <text class="modal-close" bindtap="closeProvincePicker">×</text>
      </view>
      <scroll-view class="province-picker-body" scroll-y>
        <view
          class="province-picker-item {{selectedProvinceFilter === item.value ? 'active' : ''}}"
          wx:for="{{allProvinceOptions}}"
          wx:key="value"
          bindtap="selectProvinceFromPicker"
          data-value="{{item.value}}"
        >
          <text class="province-picker-name">{{item.label}}</text>
          <text class="province-picker-count">{{item.count}} 个球场</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 球场详情弹窗 -->
  <view class="modal {{showDetailModal ? 'show' : ''}}" wx:if="{{showDetailModal}}" bindtap="closeDetailModal">
    <view class="modal-content" catchtap="preventHide">
      <view class="modal-header">
        <text class="modal-title">{{detailCourse.name}}</text>
        <text class="modal-close" bindtap="closeDetailModal">×</text>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <view class="detail-stats">
          <view class="detail-stat">
            <text class="detail-value">{{detailCourse.holes.length}}</text>
            <text class="detail-label">球洞数</text>
          </view>
          <view class="detail-stat">
            <text class="detail-value">{{detailCourse.totalPar}}</text>
            <text class="detail-label">标准杆</text>
          </view>
        </view>
        <view class="holes-detail">
          <view class="holes-header">
            <text class="holes-title">球洞明细</text>
          </view>
          <view class="holes-table">
            <view class="holes-row holes-header-row">
              <text class="hole-cell">洞</text>
              <text class="hole-cell">标准杆</text>
            </view>
            <view class="holes-row" wx:for="{{detailCourse.holes}}" wx:key="hole">
              <text class="hole-cell">{{item.hole}}</text>
              <text class="hole-cell">{{item.par}}</text>
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="modal-footer" wx:if="{{fromNewGame}}">
        <button class="btn btn-primary btn-block" bindtap="selectCourseAndBack">选择此球场</button>
      </view>
    </view>
  </view>

  <!-- 手动新增球场弹窗 -->
  <view class="modal {{showAddCourseModal ? 'show' : ''}}" wx:if="{{showAddCourseModal}}" bindtap="closeAddCourseModal">
    <view class="modal-content" catchtap="preventHide">
      <view class="modal-header">
        <text class="modal-title">手动新增球场</text>
        <text class="modal-close" bindtap="closeAddCourseModal">×</text>
      </view>
      <view class="modal-body add-course-body">
        <view class="add-course-guide">
          <text class="add-course-guide-title">没找到球场？按下面3步新增：</text>
          <text class="add-course-guide-step">1. 填写球场名称（尽量写全名）</text>
          <text class="add-course-guide-step">2. 选择所在城市</text>
          <text class="add-course-guide-step">3. 点“确认新增”，即可开始记分</text>
        </view>
        <view class="form-item">
          <text class="form-label">球场名称</text>
          <input class="form-input form-input-lg" placeholder="例如：北京高尔夫球俱乐部" value="{{newCourseName}}" bindinput="onNewCourseNameInput" />
          <view class="sample-name-wrap">
            <text class="sample-name-title">常见示例（点击自动填入）：</text>
            <view class="sample-name-list">
              <button
                class="sample-name-chip"
                wx:for="{{sampleCourseNames}}"
                wx:key="*this"
                data-name="{{item}}"
                bindtap="useSampleCourseName"
              >
                {{item}}
              </button>
            </view>
          </view>
        </view>
        <view class="form-item">
          <view class="form-label-row">
            <text class="form-label">所在城市</text>
            <button class="fill-city-btn" bindtap="fillCurrentCity">使用当前城市</button>
          </view>
          <input class="form-input form-input-lg" placeholder="例如：北京" value="{{newCourseLocation}}" bindinput="onNewCourseLocationInput" />
        </view>
        <text class="form-tip">提示：新增后默认18洞（Par4），开赛后可拍照校准标准杆。</text>
      </view>
      <view class="modal-footer">
        <button class="btn btn-secondary add-course-cancel-btn" bindtap="closeAddCourseModal">取消</button>
        <button class="btn btn-primary add-course-confirm-btn" bindtap="confirmAddCourse">确认新增并使用</button>
      </view>
    </view>
  </view>
</view>

<privacy-popup />
