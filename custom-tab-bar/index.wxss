}

.tab-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1;
  font-weight: 400;
}

.tab-bar-item.active .tab-text {
  color: #2c8f4e;
  font-weight: 500;
}

/* 中央凸起大按钮 - 独立于flex布局 */
.center-btn-wrapper {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  top: -20rpx;
  width: 120rpx;
  height: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 2;
  /* 确保能响应点击 */
  pointer-events: auto;
}

.center-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2c8f4e 0%, #1b5e20 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(44, 143, 78, 0.4);
  position: relative;
}

.center-btn-inner {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffffff 0%, #f5f5f5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: inset -2rpx -2rpx 4rpx rgba(0,0,0,0.08), inset 2rpx 2rpx 4rpx rgba(255,255,255,0.9);
}

/* 高尔夫球凹痕 */
.golf-dimples {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  overflow: hidden;
}

.dimple {
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  background: rgba(0,0,0,0.1);
  border-radius: 50%;
}

.d1 { top: 22%; left: 28%; }
.d2 { top: 38%; left: 62%; }
.d3 { top: 58%; left: 24%; }
.d4 { top: 52%; left: 72%; }

.center-btn-text-golf {
  font-size: 28rpx;
  color: #1b5e20;
  font-weight: 700;
  font-style: italic;
  z-index: 10;
}

/* 点击效果 */
.center-btn:active {
  transform: scale(0.95);
}
