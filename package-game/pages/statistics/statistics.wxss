.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.empty-state {
  min-height: 72vh;
  text-align: center;
  padding: 120rpx 48rpx;
  box-sizing: border-box;
}

.statistics-empty-icon {
  width: 150rpx;
  height: 150rpx;
  border-radius: 42rpx;
  margin-bottom: 32rpx;
  background:
    linear-gradient(90deg, transparent 24%, rgba(255,255,255,0.74) 24%, rgba(255,255,255,0.74) 31%, transparent 31%, transparent 46%, rgba(255,255,255,0.74) 46%, rgba(255,255,255,0.74) 53%, transparent 53%, transparent 68%, rgba(255,255,255,0.74) 68%, rgba(255,255,255,0.74) 75%, transparent 75%),
    linear-gradient(135deg, #2c8f4e 0%, #1b5e20 100%);
  box-shadow: 0 18rpx 40rpx rgba(44, 143, 78, 0.2);
}

.statistics-empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.statistics-empty-desc {
  max-width: 520rpx;
  margin-top: 14rpx;
  font-size: 27rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.statistics-empty-btn {
  margin-top: 42rpx;
  width: 320rpx;
  height: 84rpx;
  border-radius: 42rpx;
  font-size: 30rpx;
}

.statistics-empty-btn::after {
  border: none;
}

/* 总体概览 */
.overview-header {
  margin-bottom: 30rpx;
}

.overview-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  display: block;
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.overview-item {
  background: var(--bg-gray);
  padding: 24rpx 16rpx;
  border-radius: 12rpx;
  text-align: center;
}

.overview-value {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.overview-value.under {
  color: var(--primary);
}

.overview-value.par {
  color: #ff9800;
}

.overview-value.over {
  color: var(--danger);
}

.overview-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 成绩分布 */
.distribution-bar {
  height: 60rpx;
  display: flex;
  border-radius: 12rpx;
  overflow: hidden;
}

.dist-segment {
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 24rpx;
  font-weight: 600;
  min-width: 20rpx;
}

.dist-segment.eagle {
  background: #9c27b0;
}

.dist-segment.birdie {
  background: #2196f3;
}

.dist-segment.par {
  background: var(--primary);
}

.dist-segment.bogey {
  background: #ff9800;
}

.dist-segment.double {
  background: #f44336;
}

.distribution-legend {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-color {
  width: 24rpx;
  height: 24rpx;
  border-radius: 4rpx;
}

.legend-color.eagle {
  background: #9c27b0;
}

.legend-color.birdie {
  background: #2196f3;
}

.legend-color.par {
  background: var(--primary);
}

.legend-color.bogey {
  background: #ff9800;
}

.legend-color.double {
  background: #f44336;
}

.legend-item text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 技术短板分析 */
.analysis-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.analysis-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--bg-gray);
  border-radius: 12rpx;
}

.analysis-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.analysis-content {
  flex: 1;
}

.analysis-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4rpx;
}

.analysis-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
}

.analysis-score {
  text-align: right;
}

.score-value {
  font-size: 36rpx;
  font-weight: 700;
}

.score-value.low-score {
  color: var(--danger);
}

.score-value.medium-score {
  color: #ff9800;
}

.score-value.high-score {
  color: var(--primary);
}

/* 最近趋势 */
.trend-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 20rpx;
}

.trend-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: var(--bg-gray);
  border-radius: 12rpx;
}

.trend-round {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.round-number {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.round-date {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.trend-score {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.score-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.score-to-par {
  font-size: 22rpx;
  font-weight: 600;
}

.score-to-par.under {
  color: var(--primary);
}

.score-to-par.par {
  color: #ff9800;
}

.score-to-par.over {
  color: var(--danger);
}

.trend-indicator {
  font-size: 32rpx;
  font-weight: 700;
  width: 40rpx;
  text-align: center;
}

.trend-indicator.down {
  color: var(--primary); /* 下降说明成绩变好 */
}

.trend-indicator.up {
  color: var(--danger); /* 上升说明成绩变差 */
}

.trend-indicator.same {
  color: #999;
}

/* 趋势折线图 */
.trend-chart {
  position: relative;
  height: 240rpx;
  margin-top: 20rpx;
  padding: 0 20rpx 40rpx;
}

.chart-grid {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 40rpx;
}

.grid-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 1rpx;
  background: rgba(0,0,0,0.05);
}

.chart-line {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: calc(100% - 40rpx);
  background: var(--primary);
  z-index: 2;
}

.chart-points {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 40rpx;
}

.point {
  position: absolute;
  transform: translate(-50%, -50%);
}

.point-dot {
  width: 12rpx;
  height: 12rpx;
  background: var(--primary);
  border-radius: 50%;
  border: 3rpx solid white;
  box-shadow: 0 2rpx 6rpx rgba(44, 143, 78, 0.4);
}

.point-label {
  position: absolute;
  top: -30rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-primary);
  white-space: nowrap;
}

.chart-x-axis {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40rpx;
}

.x-label {
  position: absolute;
  bottom: 0;
  transform: translateX(-50%);
  font-size: 20rpx;
  color: var(--text-secondary);
  white-space: nowrap;
}

/* 最佳球场 */
.course-rank-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.course-rank-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--bg-gray);
  border-radius: 12rpx;
}

.course-rank-number {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary);
  color: white;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 50%;
  margin-right: 20rpx;
}

.course-rank-item:nth-child(1) .course-rank-number {
  background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
}

.course-rank-item:nth-child(2) .course-rank-number {
  background: linear-gradient(135deg, #c0c0c0 0%, #e0e0e0 100%);
}

.course-rank-item:nth-child(3) .course-rank-number {
  background: linear-gradient(135deg, #cd7f32 0%, #daa520 100%);
}

.course-rank-info {
  flex: 1;
}

.course-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4rpx;
}

.course-play-count {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
}

.course-best-score {
  text-align: right;
}

.course-best-score .score-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.course-best-score .score-to-par {
  font-size: 22rpx;
  display: block;
}

.score-to-par.under {
  color: var(--primary);
}

.score-to-par.par {
  color: #ff9800;
}

.score-to-par.over {
  color: var(--danger);
}

/* 能力雷达图 */
.radar-container {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.radar-chart {
  position: relative;
  width: 400rpx;
  height: 400rpx;
  margin-bottom: 40rpx;
}

.radar-grid {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border: 1rpx solid rgba(44, 143, 78, 0.2);
  clip-path: polygon(50% 0%, 97.55% 34.55%, 79.39% 90.45%, 20.61% 90.45%, 2.45% 34.55%);
  background: rgba(44, 143, 78, 0.03);
}

.radar-grid-1 { width: 100%; height: 100%; }
.radar-grid-2 { width: 75%; height: 75%; }
.radar-grid-3 { width: 50%; height: 50%; }
.radar-grid-4 { width: 25%; height: 25%; }

.radar-label {
  position: absolute;
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.label-drive { top: -10rpx; left: 50%; transform: translateX(-50%); }
.label-approach { top: 110rpx; right: -20rpx; }
.label-putting { bottom: -10rpx; right: 20rpx; }
.label-short { bottom: -10rpx; left: 20rpx; }
.label-stable { top: 110rpx; left: -20rpx; }

.radar-polygon {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(44, 143, 78, 0.3);
  border: 2rpx solid var(--primary);
  transition: all 0.5s ease;
}

.radar-point {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  background: var(--primary);
  border-radius: 50%;
  border: 2rpx solid white;
  box-shadow: 0 2rpx 8rpx rgba(44, 143, 78, 0.4);
}

.radar-legend {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx 32rpx;
  width: 100%;
}

.radar-legend .legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.radar-legend .legend-color {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
}

.drive-color { background: #2196f3; }
.approach-color { background: var(--primary); }
.putting-color { background: #ff9800; }
.short-color { background: #9c27b0; }
.stable-color { background: #f44336; }
