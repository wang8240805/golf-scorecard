/* 页面容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f5f5 0%, #ffffff 100%);
  padding: 30rpx;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 页面头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
  position: relative;
  padding: 0 10rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 10rpx 0;
  min-width: 100rpx;
}

.back-icon {
  font-size: 48rpx;
  color: #666;
  line-height: 1;
}

.back-text {
  font-size: 28rpx;
  color: #666;
}

.header-center {
  flex: 1;
  text-align: center;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #2c8f4e;
  font-weight: 500;
}

/* 球员选择器卡片 */
.player-selector-card {
  background: white;
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.player-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.player-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.player-initial {
  font-size: 36rpx;
  color: white;
  font-weight: 600;
}

.player-detail {
  display: flex;
  flex-direction: column;
}

.player-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.player-score {
  font-size: 26rpx;
  color: #666;
}

.style-desc.invalid {
  color: #b26b00;
}

.switch-text {
  font-size: 26rpx;
  color: #2c8f4e;
}

/* 球员选项（弹窗内） */
.player-option-content {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.player-avatar-small {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.player-option-info {
  display: flex;
  flex-direction: column;
}

/* 一句话总结 */
.summary-card {
  background: linear-gradient(135deg, #2c8f4e 0%, #1b5e20 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.summary-text {
  font-size: 30rpx;
  color: white;
  line-height: 1.6;
}

/* 赢家卡片 */
.winner-card {
  background: linear-gradient(135deg, #FFD700 0%, #FFA000 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 160, 0, 0.3);
  overflow: visible;
}

.winner-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.winner-icon {
  font-size: 40rpx;
}

.winner-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

.winner-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
}

.winner-player {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 16rpx;
  padding: 20rpx;
}

.winner-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.winner-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.winner-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.winner-score {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
}

.winner-desc {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 16rpx;
}

/* 深度数据分析卡片 */
.deep-analysis-card {
  background: linear-gradient(135deg, #2c8f4e 0%, #1b5e20 100%);
  color: white;
}

.deep-analysis-card .section-title {
  color: white;
  margin-bottom: 30rpx;
}

.analysis-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.analysis-item {
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  backdrop-filter: blur(10rpx);
}

.analysis-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 8rpx;
}

.analysis-label {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  margin-bottom: 12rpx;
}

.analysis-comment {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.75);
  line-height: 1.4;
}

/* 通用卡片 */
.card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 数据概览 */
.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-value.under {
  color: #2c8f4e;
}

.stat-value.over {
  color: #f44336;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 表现评级 */
.rating-card {
  text-align: center;
}

.rating-title {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.rating-circle {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 20rpx;
  background: linear-gradient(135deg, #2c8f4e 0%, #1b5e20 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(44, 143, 78, 0.28);
}

.rating-score {
  font-size: 72rpx;
  font-weight: 700;
  color: white;
  line-height: 1;
}

.rating-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 8rpx;
}

.stars {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.star {
  font-size: 40rpx;
  color: #e0e0e0;
}

.star.filled {
  color: #FFD700;
}

/* 亮点 */
.highlight-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.highlight-item {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  padding: 24rpx;
  border-radius: 16rpx;
  border-left: 8rpx solid #2c8f4e;
}

.highlight-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1b5e20;
  margin-bottom: 8rpx;
}

.highlight-content {
  display: block;
  font-size: 26rpx;
  color: #4caf50;
  line-height: 1.5;
}

/* 弱点分析 */
.weakness-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.weakness-item {
  background: #fff8e1;
  padding: 24rpx;
  border-radius: 16rpx;
  border-left: 8rpx solid #ff9800;
}

.weakness-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #e65100;
  margin-bottom: 8rpx;
}

.weakness-content {
  display: block;
  font-size: 26rpx;
  color: #f57c00;
  line-height: 1.5;
}

/* 历史对比 */
.comparison-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 24rpx;
}

.comparison-stat {
  text-align: center;
}

.comparison-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.comparison-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #666;
}

.comparison-value.current {
  color: #2c8f4e;
}

.comparison-arrow {
  font-size: 48rpx;
  color: #2c8f4e;
  font-weight: 700;
}

.comparison-text {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
}

/* AI 建议 */
.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.suggestion-item {
  background: #e3f2fd;
  padding: 24rpx;
  border-radius: 12rpx;
  border-left: 8rpx solid #2196f3;
}

.suggestion-text {
  font-size: 28rpx;
  color: #1976d2;
  line-height: 1.6;
}

/* 分享按钮 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 30rpx calc(40rpx + env(safe-area-inset-bottom));
  background: white;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  gap: 20rpx;
}

.share-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #2c8f4e 0%, #1b5e20 100%);
  color: white;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.share-btn::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
}

/* 海报选择弹窗 */
.poster-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
  z-index: 1000;
}

.poster-modal.show {
  opacity: 1;
  visibility: visible;
}

.poster-modal-content {
  background: white;
  border-radius: 40rpx 40rpx 0 0;
  width: 100%;
  padding: 40rpx 30rpx calc(40rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: all 0.3s;
}

.poster-modal.show .poster-modal-content {
  transform: translateY(0);
}

.poster-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.poster-modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.poster-modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.style-option {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  border: 4rpx solid transparent;
}

.style-option.selected {
  border-color: #2c8f4e;
  background: #e8f5e9;
}

.style-preview {
  flex: 1;
}

.style-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.style-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
}

.style-check {
  font-size: 36rpx;
  color: #2c8f4e;
  font-weight: 600;
}

.generate-btn {
  width: 100%;
  height: 96rpx;
  margin-top: 20rpx;
  background: linear-gradient(135deg, #2c8f4e 0%, #1b5e20 100%);
  color: white;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.generate-btn::after {
  border: none;
}

/* 背景选择样式 */
.section-subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.bg-options {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.bg-option {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  border: 4rpx solid transparent;
  overflow: hidden;
}

.bg-option.selected {
  border-color: #2c8f4e;
}

.bg-preview {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.bg-preview text {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

.bg-preview .add-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.default-bg {
  background: linear-gradient(135deg, #2c8f4e 0%, #1b5e20 100%);
}

.default-bg text {
  color: white;
}

.course-bg {
  background: linear-gradient(180deg, #87CEEB 0%, #7CB342 100%);
}

.course-bg text {
  color: white;
}

.sunset-bg {
  background: linear-gradient(180deg, #FF6B6B 0%, #FFE66D 50%, #4ECDC4 100%);
}

.sunset-bg text {
  color: white;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

.green-bg {
  background: linear-gradient(135deg, #2E7D32 0%, #4CAF50 50%, #2E7D32 100%);
}

.green-bg text {
  color: white;
}

.custom-bg {
  background: #f5f5f5;
  border: 2rpx dashed #ccc;
}

.custom-bg text {
  color: #666;
}

.custom-bg-preview {
  margin-top: 20rpx;
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.custom-bg-preview image {
  width: 100%;
  height: 100%;
}

.remove-bg {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  color: white;
  border-radius: 50%;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 自定义背景上传区域 */
.section-divider {
  height: 1rpx;
  background: #eee;
  margin: 30rpx 0;
}

.custom-bg-upload {
  margin-bottom: 20rpx;
}

.upload-area {
  background: #f9f9f9;
  border: 2rpx dashed #ddd;
  border-radius: 16rpx;
  padding: 40rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  min-height: 180rpx;
}

.upload-area.has-image {
  padding: 0;
  min-height: 200rpx;
  border-style: solid;
  border-color: #2c8f4e;
}

.upload-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.upload-tip {
  font-size: 24rpx;
  color: #999;
}

.upload-preview {
  width: 100%;
  height: 200rpx;
  object-fit: cover;
}

.upload-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.reupload-text {
  color: white;
  font-size: 28rpx;
  font-weight: 500;
  padding: 12rpx 30rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 30rpx;
}

.use-custom-bg-option {
  margin-top: 16rpx;
}

.checkbox-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 10rpx 0;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #ccc;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: white;
}

.checkbox.checked {
  background: #2c8f4e;
  border-color: #2c8f4e;
}

.checkbox.checked text {
  color: white;
  font-size: 26rpx;
  font-weight: bold;
}

.checkbox-label {
  font-size: 28rpx;
  color: #333;
}

/* 风格示意图预览 - 在选择弹窗中显示 */
.style-preview-thumbnail {
  width: 120rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.thumb-pro {
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #1a3a2a 0%, #0d1f17 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.thumb-pro::before {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60%;
  height: 3rpx;
  background: #d4af37;
}

.thumb-pro .thumb-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.thumb-pro .thumb-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #d4af37;
}

.thumb-minimal {
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #1b5e20 0%, #E8F5E9 30%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.thumb-minimal .thumb-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
  margin-top: 20rpx;
}

.thumb-minimal .thumb-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #2e7d32;
}

.thumb-fun {
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #FF8A65 0%, #FFCC80 50%, #A5D6A7 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.thumb-fun .thumb-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.thumb-fun .thumb-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #e65100;
}

.style-info {
  flex: 1;
  margin-left: 24rpx;
}

/* 新的海报预览弹窗 - 全屏滚动 */
.poster-preview-content-wide {
  background: #f5f5f5;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.poster-config-panel {
  flex: 1;
  padding: 30rpx;
  box-sizing: border-box;
}

.config-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.poster-image-large {
  width: 100%;
  max-width: 600rpx;
  margin: 0 auto 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
  display: block;
}

.config-section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.config-label {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.bg-options-compact {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.bg-option-compact {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  border: 4rpx solid transparent;
  background: #f5f5f5;
}

.bg-option-compact.selected {
  border-color: #2c8f4e;
  background: #e8f5e9;
}

.bg-option-compact text {
  font-size: 24rpx;
  color: #666;
}

.bg-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
}

.bg-thumb .add-icon {
  font-size: 40rpx;
  color: #999;
}

.custom-bg-mini {
  margin-top: 20rpx;
  position: relative;
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.custom-bg-mini image {
  width: 100%;
  height: 100%;
}

.remove-mini {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 32rpx;
  height: 32rpx;
  background: rgba(0,0,0,0.5);
  color: white;
  border-radius: 50%;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.poster-actions-vertical {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.poster-actions-vertical .btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
}

/* 海报预览弹窗 */
.poster-preview-content {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 40rpx;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.poster-image {
  width: 100%;
  max-width: 560rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 30rpx;
}

.poster-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.poster-actions .btn {
  flex: 1;
}

/* Canvas */
.poster-canvas {
  position: fixed;
  top: -9999rpx;
  left: -9999rpx;
  width: 750rpx;
  height: 1334rpx;
}
