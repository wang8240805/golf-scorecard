<view class="container history-page">
  <view class="empty-state" wx:if="{{games.length === 0}}">
    <view class="history-empty-icon"></view>
    <text class="history-empty-title">暂无比赛记录</text>
    <text class="history-empty-desc">完成一场18洞比赛后，成绩和统计会保存在这里</text>
    <button class="btn btn-primary history-empty-btn" bindtap="startNewGame">开始新比赛</button>
  </view>

  <block wx:if="{{games.length > 0}}">
    <view class="history-summary">
      <view class="summary-main">
        <text class="summary-value">{{completedGameCount}}</text>
        <text class="summary-label">完成场次</text>
      </view>
      <view class="summary-metrics">
        <view class="summary-metric">
          <text class="metric-value">{{avgScore || '-'}}</text>
          <text class="metric-label">平均杆</text>
        </view>
        <view class="summary-metric">
          <text class="metric-value">{{bestScore || '-'}}</text>
          <text class="metric-label">最佳</text>
        </view>
        <view class="summary-metric">
          <text class="metric-value">{{totalPlayers}}</text>
          <text class="metric-label">球友</text>
        </view>
      </view>
    </view>

    <view class="history-toolbar">
      <text class="history-title">比赛记录</text>
      <text class="history-count">{{totalGameCount}} 条</text>
    </view>

    <view class="history-list">
      <view class="history-row {{item.statusClass}}" wx:for="{{games}}" wx:key="historyKey" bindtap="viewDetail" data-game="{{item}}">
        <view class="row-date">
          <text class="row-date-day">{{item.dateMonthDay}}</text>
          <text class="row-date-year">{{item.dateYear}}</text>
        </view>

        <view class="row-main">
          <view class="row-title-line">
            <text class="row-title">{{item.courseName || '未知球场'}}</text>
            <text class="row-status {{item.statusClass}}">{{item.statusText}}</text>
          </view>
          <view class="row-meta">
            <text>{{item.playerCount || 0}}人</text>
            <text class="meta-dot">·</text>
            <text>{{item.holesPlayed || 0}}/{{item.holesTotal || 18}}洞</text>
            <text class="meta-dot">·</text>
            <text class="row-to-par {{'to-par-' + (item.toParClass || 'empty')}}">{{item.toParText || '-'}}</text>
          </view>
        </view>

        <view class="row-side">
          <view class="row-score">
            <text class="score-value">{{item.myScore || '-'}}</text>
            <text class="score-unit">杆</text>
          </view>
          <text class="row-action {{item.statusClass}}">{{item.actionText}}</text>
        </view>

        <view class="row-delete" catchtap="deleteGame" data-game="{{item}}">
          <text>删除</text>
        </view>
      </view>
    </view>

    <view class="load-more" wx:if="{{hasMore}}">
      <text bindtap="loadMore">加载更多</text>
    </view>
  </block>
</view>
