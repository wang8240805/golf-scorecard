.empty-state {
  min-height: 72vh;
  text-align: center;
  padding: 120rpx 48rpx;
  box-sizing: border-box;
}

.history-empty-icon {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  margin-bottom: 32rpx;
  background:
    radial-gradient(circle at 50% 44%, #ffffff 0 18rpx, transparent 19rpx),
    linear-gradient(135deg, #2c8f4e 0%, #1b5e20 100%);
  box-shadow: 0 18rpx 40rpx rgba(44, 143, 78, 0.22);
}

.history-empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.history-empty-desc {
  max-width: 520rpx;
  margin-top: 14rpx;
  font-size: 27rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.history-empty-btn {
  margin-top: 42rpx;
  width: 320rpx;
  height: 84rpx;
  border-radius: 42rpx;
  font-size: 30rpx;
}

.history-empty-btn::after {
  border: none;
}

.overview-card {
  background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 100%);
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.overview-item {
  text-align: center;
  color: white;
}

.overview-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.overview-label {
  display: block;
  font-size: 24rpx;
  opacity: 0.8;
}

.game-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.game-card {
  background: #f8faf8;
  border: 1rpx solid #e8f0ea;
  border-radius: 14rpx;
  overflow: hidden;
}

.history-game-item {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 136rpx;
  padding: 18rpx;
  box-sizing: border-box;
}

.history-game-item.incomplete {
  background: linear-gradient(135deg, #fffaf2 0%, #f8faf8 70%);
  border-color: #f1d8b6;
}

.history-game-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 14rpx;
}

.history-game-info {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.history-game-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.history-game-name {
  flex: 1;
  min-width: 0;
  display: block;
  font-size: 29rpx;
  line-height: 1.25;
  color: #26322b;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-status-pill {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 34rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1;
}

.history-status-pill.completed {
  color: #1b7f45;
  background: #e8f5e9;
}

.history-status-pill.incomplete {
  color: #b25b00;
  background: #fff0d6;
}

.history-game-date {
  display: block;
  font-size: 22rpx;
  line-height: 1.2;
  color: #8b9690;
}

.history-game-meta-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.history-game-meta {
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #eef3ef;
  color: #637069;
  font-size: 21rpx;
  font-weight: 500;
  line-height: 1;
  box-sizing: border-box;
}

.history-game-meta.warning {
  color: #b25b00;
  background: #fff0d6;
}

.history-game-to-par.to-par-over {
  color: #c24a2d;
  background: #fff0e8;
}

.history-game-to-par.to-par-under {
  color: #1b7f45;
  background: #e8f5e9;
}

.history-game-to-par.to-par-even {
  color: #5f6b7a;
  background: #eef1f4;
}

.history-game-to-par.to-par-empty {
  color: #9aa4af;
  background: #f4f6f8;
}

.history-game-side {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.history-game-scorebox {
  width: 112rpx;
  min-width: 112rpx;
  min-height: 100%;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e2ece5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.history-game-score {
  font-size: 36rpx;
  line-height: 1;
  color: var(--primary);
  font-weight: 700;
}

.history-game-score-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #8b9690;
  line-height: 1;
}

.expand-icon {
  font-size: 36rpx;
  color: var(--text-light);
  transition: transform 0.2s;
  transform: rotate(90deg);
}

.expand-icon.expanded {
  transform: rotate(-90deg);
}

.game-detail {
  padding: 0 18rpx 18rpx;
  border-top: 1rpx solid #e8f0ea;
  background: #ffffff;
}

.detail-section {
  margin-top: 20rpx;
}

.section-label {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 16rpx;
}

.detail-players {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-player {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  background: white;
  border-radius: 8rpx;
}

.detail-player-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.player-avatar-sm {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 24rpx;
  font-weight: 600;
}

.detail-player-name {
  font-size: 28rpx;
  color: var(--text-primary);
}

.detail-player-score {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.detail-total {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.detail-to-par {
  font-size: 24rpx;
  color: var(--text-light);
  background: var(--bg-gray);
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.detail-to-par.under {
  color: var(--primary);
  background: #e8f5e9;
}

.detail-to-par.over {
  color: var(--danger);
  background: #ffebee;
}

.detail-stats {
  display: flex;
  justify-content: space-around;
  padding: 20rpx;
  background: white;
  border-radius: 8rpx;
}

.detail-stat {
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.stat-desc {
  font-size: 22rpx;
  color: var(--text-light);
}

.detail-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.detail-actions .btn {
  flex: 1;
}

.load-more {
  text-align: center;
  padding: 30rpx;
}

.load-more text {
  font-size: 28rpx;
  color: var(--primary);
}
