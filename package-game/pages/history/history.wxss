.history-page {
  --history-ink: #26322b;
  --history-muted: #7a8780;
  --history-line: #e4ebe6;
  --history-soft: #f7faf8;
  --history-warn: #b25b00;
  background: #f4f7f5;
}

.empty-state {
  min-height: 72vh;
  text-align: center;
  padding: 120rpx 48rpx;
  box-sizing: border-box;
}

.history-empty-icon {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  margin-bottom: 32rpx;
  background:
    radial-gradient(circle at 50% 44%, #ffffff 0 18rpx, transparent 19rpx),
    linear-gradient(135deg, #2c8f4e 0%, #1b5e20 100%);
  box-shadow: 0 18rpx 40rpx rgba(44, 143, 78, 0.22);
}

.history-empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.history-empty-desc {
  max-width: 520rpx;
  margin-top: 14rpx;
  font-size: 27rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.history-empty-btn {
  margin-top: 42rpx;
  width: 320rpx;
  height: 84rpx;
  border-radius: 42rpx;
  font-size: 30rpx;
}

.history-empty-btn::after {
  border: none;
}

.history-summary {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
  padding: 24rpx;
  margin-bottom: 26rpx;
  border-radius: 8rpx;
  background: #ffffff;
  border: 1rpx solid var(--history-line);
}

.summary-main {
  width: 154rpx;
  min-width: 154rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  border-right: 1rpx solid var(--history-line);
}

.summary-value {
  font-size: 48rpx;
  line-height: 1;
  font-weight: 700;
  color: var(--primary);
}

.summary-label {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--history-muted);
}

.summary-metrics {
  flex: 1;
  min-width: 0;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.summary-metric {
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.metric-value {
  max-width: 100%;
  font-size: 34rpx;
  line-height: 1.1;
  font-weight: 700;
  color: var(--history-ink);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.metric-label {
  margin-top: 8rpx;
  font-size: 21rpx;
  color: var(--history-muted);
}

.history-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 2rpx 14rpx;
}

.history-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--history-ink);
}

.history-count {
  font-size: 23rpx;
  color: var(--history-muted);
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.history-row {
  position: relative;
  min-height: 128rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 86rpx 18rpx 18rpx;
  border-radius: 8rpx;
  background: #ffffff;
  border: 1rpx solid var(--history-line);
  box-sizing: border-box;
}

.history-row:active {
  background: #eef5f0;
}

.history-row.incomplete {
  border-color: #ead8bd;
  background: #fffaf2;
}

.row-date {
  width: 88rpx;
  min-width: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.row-date-day {
  font-size: 28rpx;
  line-height: 1.1;
  font-weight: 700;
  color: var(--history-ink);
}

.row-date-year {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: var(--history-muted);
}

.row-main {
  flex: 1;
  min-width: 0;
}

.row-title-line {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.row-title {
  flex: 1;
  min-width: 0;
  font-size: 29rpx;
  line-height: 1.25;
  font-weight: 600;
  color: var(--history-ink);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-status {
  flex-shrink: 0;
  height: 32rpx;
  padding: 0 10rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  line-height: 32rpx;
  color: #1b7f45;
  background: #e8f5e9;
}

.row-status.incomplete {
  color: var(--history-warn);
  background: #fff0d6;
}

.row-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1;
  color: var(--history-muted);
}

.meta-dot {
  color: #b7c0bb;
}

.row-to-par {
  font-weight: 700;
}

.row-to-par.to-par-over {
  color: #c24a2d;
}

.row-to-par.to-par-under {
  color: #1b7f45;
}

.row-to-par.to-par-even {
  color: #5f6b7a;
}

.row-to-par.to-par-empty {
  color: #9aa4af;
}

.row-side {
  width: 94rpx;
  min-width: 94rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.row-score {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  min-height: 42rpx;
}

.score-value {
  font-size: 38rpx;
  line-height: 1;
  font-weight: 700;
  color: var(--primary);
}

.score-unit {
  margin-left: 4rpx;
  font-size: 19rpx;
  color: var(--history-muted);
}

.row-action {
  margin-top: 11rpx;
  font-size: 22rpx;
  color: var(--primary);
}

.row-action.incomplete {
  color: var(--history-warn);
}

.row-delete {
  position: absolute;
  right: 14rpx;
  top: 50%;
  width: 56rpx;
  height: 56rpx;
  margin-top: -28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  color: #c24a2d;
  background: #fff0e8;
  font-size: 20rpx;
  line-height: 1;
}

.row-delete:active {
  background: #ffd9c9;
}

.load-more {
  text-align: center;
  padding: 34rpx;
}

.load-more text {
  font-size: 28rpx;
  color: var(--primary);
}
